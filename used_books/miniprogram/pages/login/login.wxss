/* ==================== 微信快捷登录页面 - 主题样式 ==================== */

page {
      background: #0a0f1a;
      color: #fff;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      min-height: 100vh;
}

/* 微信快捷登录容器 */
.wechat-login-container {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 60rpx 40rpx;
      min-height: 100vh;
      box-sizing: border-box;
}

/* 顶部logo */
.logo-section {
      display: flex;
      flex-direction: column;
      align-items: center;
      margin-bottom: 80rpx;
      margin-top: 40rpx;
}

.logo {
      width: 140rpx;
      height: 140rpx;
      border-radius: 28rpx;
      margin-bottom: 24rpx;
      box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
}

.app-name {
      font-size: 40rpx;
      font-weight: 700;
      color: #fff;
      letter-spacing: 4rpx;
      margin-bottom: 12rpx;
      text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.app-slogan {
      font-size: 24rpx;
      color: rgba(255, 255, 255, 0.8);
      letter-spacing: 2rpx;
}

/* 用户头像和昵称 */
.user-avatar {
      width: 140rpx;
      height: 140rpx;
      border-radius: 70rpx;
      margin-bottom: 20rpx;
      border: 4rpx solid rgba(0, 212, 255, 0.3);
      box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

.user-name {
      font-size: 36rpx;
      font-weight: 600;
      color: #fff;
      margin-bottom: 12rpx;
}

/* 登录表单 */
.login-form {
      width: 100%;
      max-width: 600rpx;
      background: rgba(26, 31, 46, 0.8);
      border-radius: 24rpx;
      padding: 40rpx;
      margin-bottom: 60rpx;
      border: 1rpx solid rgba(0, 212, 255, 0.1);
      box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

/* 表单项 */
.form-item {
      display: flex;
      align-items: center;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 16rpx;
      padding: 24rpx;
      margin-bottom: 24rpx;
      border: 1rpx solid rgba(0, 212, 255, 0.1);
}

.form-item:last-child {
      margin-bottom: 0;
}

.form-icon {
      width: 40rpx;
      height: 40rpx;
      margin-right: 20rpx;
      opacity: 0.8;
}

/* 表单标签 */
.form-label {
      font-size: 28rpx;
      color: rgba(255, 255, 255, 0.7);
      margin-right: 20rpx;
      width: 80rpx;
      flex-shrink: 0;
}

/* 头像选择 */
.avatar-item {
      justify-content: flex-start;
}

.avatar-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      background: transparent;
      padding: 0;
      margin: 0;
      line-height: normal;
}

.avatar-btn::after {
      border: none;
}

.avatar-preview {
      width: 100rpx;
      height: 100rpx;
      border-radius: 50rpx;
      border: 2rpx solid rgba(0, 212, 255, 0.3);
      margin-bottom: 8rpx;
}

.avatar-hint {
      font-size: 20rpx;
      color: rgba(255, 255, 255, 0.5);
}

/* 昵称输入 */
.nickname-input {
      flex: 1;
      height: 60rpx;
      font-size: 30rpx;
      color: #fff;
      background: transparent;
}

.nickname-input::placeholder {
      color: rgba(255, 255, 255, 0.4);
}

.picker {
      flex: 1;
}

.picker-content {
      display: flex;
      align-items: center;
      justify-content: space-between;
}

.picker-label {
      font-size: 28rpx;
      color: rgba(255, 255, 255, 0.7);
      margin-right: 20rpx;
}

.picker-value {
      flex: 1;
      font-size: 30rpx;
      color: #fff;
      font-weight: 500;
}

.picker-arrow {
      width: 28rpx;
      height: 28rpx;
      opacity: 0.6;
      transform: rotate(90deg);
}

/* 协议 */
.agreement {
      display: flex;
      align-items: flex-start;
      padding: 0 8rpx;
}

.checkbox {
      width: 36rpx;
      height: 36rpx;
      margin-right: 16rpx;
      margin-top: 2rpx;
      border: 2rpx solid rgba(255, 255, 255, 0.5);
      border-radius: 8rpx;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s ease;
      flex-shrink: 0;
}

.checkbox.checked {
      background: #00d4ff;
      border-color: #00d4ff;
}

.checkbox-inner {
      width: 18rpx;
      height: 10rpx;
      border-left: 3rpx solid transparent;
      border-bottom: 3rpx solid transparent;
      transform: rotate(-45deg);
      margin-top: -4rpx;
      transition: all 0.2s ease;
}

.checkbox.checked .checkbox-inner {
      border-left-color: #fff;
      border-bottom-color: #fff;
}

.agreement-text {
      flex: 1;
      font-size: 24rpx;
      color: rgba(255, 255, 255, 0.8);
      line-height: 1.5;
}

.link {
      color: #00d4ff;
}

/* 登录按钮区域 */
.login-section {
      width: 100%;
      max-width: 600rpx;
}

.wechat-login-btn {
      width: 100%;
      height: 100rpx;
      background: linear-gradient(135deg, #00d4ff 0%, #00a0d6 100%);
      border-radius: 50rpx;
      font-size: 32rpx;
      font-weight: 600;
      color: #0a0f1a;
      line-height: 100rpx;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8rpx 24rpx rgba(0, 212, 255, 0.3);
      transition: all 0.3s ease;
}

.wechat-login-btn:hover {
      transform: translateY(-2rpx);
      box-shadow: 0 12rpx 32rpx rgba(0, 212, 255, 0.4);
}

.wechat-login-btn:disabled {
      background: rgba(0, 212, 255, 0.3);
      transform: none;
      box-shadow: none;
}

.btn-icon {
      width: 40rpx;
      height: 40rpx;
      margin-right: 16rpx;
}

/* 响应式设计 */
@media (max-width: 375px) {
      .wechat-login-container {
            padding: 40rpx 30rpx;
      }
      
      .logo-section {
            margin-bottom: 60rpx;
            margin-top: 20rpx;
      }
      
      .logo {
            width: 120rpx;
            height: 120rpx;
      }
      
      .app-name {
            font-size: 36rpx;
      }
      
      .login-form {
            padding: 30rpx;
            margin-bottom: 40rpx;
      }
      
      .wechat-login-btn {
            height: 90rpx;
            line-height: 90rpx;
            font-size: 30rpx;
      }
}
