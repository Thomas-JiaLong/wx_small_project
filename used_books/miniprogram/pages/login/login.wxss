/* 页面背景 */
page {
      background: linear-gradient(180deg, #f0f4f8 0%, #ffffff 100%);
      min-height: 100vh;
}

/* 顶部渐变背景 */
.top-bg {
      position: relative;
      width: 100%;
      height: 420rpx;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      border-radius: 0 0 60rpx 60rpx;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      overflow: hidden;
}

/* 装饰圆点 */
.dot {
      position: absolute;
      border-radius: 50%;
      opacity: 0.1;
}

.dot1 {
      width: 300rpx;
      height: 300rpx;
      background: #fff;
      top: -100rpx;
      right: -50rpx;
}

.dot2 {
      width: 200rpx;
      height: 200rpx;
      background: #fff;
      bottom: 50rpx;
      left: -80rpx;
}

.dot3 {
      width: 100rpx;
      height: 100rpx;
      background: #fff;
      top: 100rpx;
      left: 60rpx;
}

/* Logo容器 */
.logo-container {
      width: 140rpx;
      height: 140rpx;
      background: #fff;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.15);
      margin-bottom: 20rpx;
}

.logo {
      width: 120rpx;
      height: 120rpx;
      border-radius: 50%;
}

.app-name {
      font-size: 40rpx;
      font-weight: 600;
      color: #fff;
      letter-spacing: 4rpx;
      margin-bottom: 10rpx;
}

.app-slogan {
      font-size: 26rpx;
      color: rgba(255, 255, 255, 0.8);
      letter-spacing: 2rpx;
}

/* 主容器 */
.contain {
      position: relative;
      z-index: 10;
      padding: 0 40rpx 60rpx;
      margin-top: -60rpx;
}

/* 卡片 */
.card {
      background: #fff;
      border-radius: 32rpx;
      padding: 50rpx 40rpx;
      box-shadow: 0 10rpx 50rpx rgba(0, 0, 0, 0.08);
}

.title {
      font-size: 44rpx;
      font-weight: 600;
      color: #333;
      text-align: center;
      margin-bottom: 10rpx;
}

.subtitle {
      font-size: 26rpx;
      color: #999;
      text-align: center;
      margin-bottom: 50rpx;
}

/* 输入组 */
.input-group {
      display: flex;
      align-items: center;
      height: 100rpx;
      background: #f7f8fa;
      border-radius: 16rpx;
      padding: 0 30rpx;
      margin-bottom: 30rpx;
      transition: all 0.3s ease;
      border: 2rpx solid transparent;
}

.input-group:focus-within {
      background: #fff;
      border-color: #667eea;
      box-shadow: 0 0 0 6rpx rgba(102, 126, 234, 0.1);
}

.input-icon {
      width: 44rpx;
      height: 44rpx;
      margin-right: 20rpx;
      opacity: 0.6;
}

.input-group input {
      flex: 1;
      height: 100%;
      font-size: 32rpx;
      color: #333;
}

.placeholder {
      color: #bbb;
      font-size: 32rpx;
}

/* 选择器样式 */
.picker-box {
      flex: 1;
      height: 100%;
}

.picker-content {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 100%;
      font-size: 32rpx;
      color: #bbb;
}

.picker-content .has-value {
      color: #333;
}

.arrow {
      width: 28rpx;
      height: 28rpx;
      opacity: 0.4;
}

/* 注册按钮 */
.confirm {
      width: 100%;
      height: 100rpx;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      border-radius: 50rpx;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-top: 40rpx;
      box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.4);
      border: none;
      transition: all 0.3s ease;
}

.confirm::after {
      border: none;
}

.confirm:active {
      transform: scale(0.98);
      box-shadow: 0 5rpx 20rpx rgba(102, 126, 234, 0.3);
}

.confirm text {
      color: #fff;
      font-size: 34rpx;
      font-weight: 500;
      letter-spacing: 4rpx;
}

/* 使用说明 */
.shen_title {
      display: flex;
      align-items: center;
      margin-top: 50rpx;
      margin-bottom: 20rpx;
}

.shen_title text {
      font-size: 28rpx;
      color: #666;
      font-weight: 500;
}

.about {
      width: 32rpx;
      height: 32rpx;
      margin-right: 10rpx;
}

.des {
      font-size: 24rpx;
      color: #aaa;
      line-height: 44rpx;
      padding-left: 20rpx;
}

/* 图标占位符（如果没有图标文件，用emoji代替） */
.input-icon[src="/images/email-icon.png"],
.input-icon[src="/images/weixin-icon.png"] {
      opacity: 0.5;
}
