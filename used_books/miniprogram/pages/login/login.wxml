<!-- 微信快捷登录页面 -->
<view class="wechat-login-container">
      <!-- 顶部logo/用户信息 -->
      <view class="logo-section">
            <block wx:if="{{userInfo.nickName && userInfo.nickName !== '微信用户'}}">
                  <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
                  <view class="user-name">{{userInfo.nickName}}</view>
            </block>
            <block wx:else>
                  <image class="logo" src="/images/logo.png" mode="aspectFill"></image>
                  <view class="app-name">正培舟海旧书</view>
            </block>
            <view class="app-slogan">校园旧书交易平台</view>
      </view>

      <!-- 登录表单 -->
      <view class="login-form">
            <!-- 头像选择 - 仅在需要完善信息时显示 -->
            <view class="form-item avatar-item" wx:if="{{showUserInfoForm}}">
                  <text class="form-label">头像</text>
                  <button class="avatar-btn" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
                        <image class="avatar-preview" src="{{tempAvatarUrl || '/images/avator.png'}}" mode="aspectFill"></image>
                        <text class="avatar-hint">点击选择</text>
                  </button>
            </view>

            <!-- 昵称输入 - 仅在需要完善信息时显示 -->
            <view class="form-item" wx:if="{{showUserInfoForm}}">
                  <text class="form-label">昵称</text>
                  <input 
                        class="nickname-input" 
                        type="nickname" 
                        placeholder="请输入昵称" 
                        value="{{tempNickName}}"
                        bind:input="onNickNameInput"
                  />
            </view>

            <!-- 校区选择 -->
            <view class="form-item">
                  <image class="form-icon" src="/images/local.png"></image>
                  <picker class="picker" bindchange="chooseCampus" value="{{campusIndex}}" range="{{campus}}" range-key="name">
                        <view class="picker-content">
                              <text class="picker-label">校区</text>
                              <text class="picker-value">{{campus[campusIndex].name}}</text>
                              <image class="picker-arrow" src="/images/right.png"></image>
                        </view>
                  </picker>
            </view>

            <!-- 协议勾选 -->
            <view class="agreement">
                  <view class="checkbox {{agreed ? 'checked' : ''}}" bindtap="toggleAgreement">
                        <view class="checkbox-inner"></view>
                  </view>
                  <view class="agreement-text">
                        登录即表示您已阅读并同意
                        <text class="link" bindtap="goToAgreement">《用户协议》</text>
                        和
                        <text class="link" bindtap="goToPrivacy">《隐私政策》</text>
                  </view>
            </view>
      </view>

      <!-- 登录按钮 -->
      <view class="login-section">
            <button class="wechat-login-btn" bindtap="wechatLogin" disabled="{{isLoggingIn}}">
                  <text>{{isLoggingIn ? '登录中...' : (showUserInfoForm ? '确认登录' : '微信快捷登录')}}</text>
            </button>
      </view>
</view>
