.container {
      padding: 24rpx;
      background: #f5f5f5;
      min-height: 100vh;
}

.header {
      text-align: center;
      margin-bottom: 40rpx;
}

.title {
      font-size: 36rpx;
      font-weight: 600;
      color: #333;
      margin-bottom: 12rpx;
}

.subtitle {
      font-size: 24rpx;
      color: #666;
}

.upload-section {
      text-align: center;
      margin-bottom: 40rpx;
}

.upload-btn {
      width: 200rpx;
      height: 80rpx;
      line-height: 80rpx;
      font-size: 28rpx;
      background: #007aff;
      color: #fff;
      border-radius: 40rpx;
}

.tip {
      display: block;
      margin-top: 16rpx;
      font-size: 20rpx;
      color: #999;
}

.image-list {
      margin-bottom: 40rpx;
}

.image-item {
      display: flex;
      align-items: center;
      background: #fff;
      padding: 24rpx;
      border-radius: 16rpx;
      margin-bottom: 16rpx;
      box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.image-preview {
      width: 100rpx;
      height: 100rpx;
      border-radius: 8rpx;
      margin-right: 20rpx;
}

.image-info {
      flex: 1;
}

.icon-key {
      width: 100%;
      height: 60rpx;
      border: 1rpx solid #ddd;
      border-radius: 8rpx;
      padding: 0 16rpx;
      font-size: 28rpx;
}

.remove-btn {
      width: 40rpx;
      height: 40rpx;
      line-height: 40rpx;
      text-align: center;
      background: #ff4757;
      color: #fff;
      border-radius: 50%;
      font-size: 32rpx;
      font-weight: bold;
      margin-left: 16rpx;
}

.upload-all-btn {
      width: 100%;
      height: 88rpx;
      line-height: 88rpx;
      font-size: 32rpx;
      background: #52c41a;
      color: #fff;
      border-radius: 44rpx;
      margin-bottom: 40rpx;
}

.upload-all-btn:disabled {
      background: #ccc;
}

.log-section {
      background: #fff;
      border-radius: 16rpx;
      padding: 24rpx;
      box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.log-title {
      font-size: 28rpx;
      font-weight: 600;
      color: #333;
      margin-bottom: 16rpx;
}

.log-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12rpx 0;
      border-bottom: 1rpx solid #f0f0f0;
}

.log-item:last-child {
      border-bottom: none;
}

.log-key {
      font-size: 24rpx;
      color: #333;
}

.log-status {
      font-size: 24rpx;
      font-weight: 600;
}

.log-status.success {
      color: #52c41a;
}

.log-status.fail {
      color: #ff4757;
}
