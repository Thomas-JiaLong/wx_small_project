<view class="container">
      <view class="header">
            <text class="title">图标管理</text>
            <text class="subtitle">将本地图片上传到云数据库</text>
      </view>

      <view class="upload-section">
            <button class="upload-btn" bindtap="selectImages">选择图片</button>
            <text class="tip">支持 PNG、JPG、GIF 格式</text>
      </view>

      <view class="image-list" wx:if="{{images.length > 0}}">
            <view class="image-item" wx:for="{{images}}" wx:key="index">
                  <image class="image-preview" src="{{item.path}}" mode="aspectFit"></image>
                  <view class="image-info">
                        <input 
                              class="icon-key" 
                              placeholder="输入图标键名（如: scan, logo）" 
                              value="{{item.key}}" 
                              bindinput="updateKey" 
                              data-index="{{index}}"
                        />
                  </view>
                  <view class="remove-btn" bindtap="removeImage" data-index="{{index}}">×</view>
            </view>
      </view>

      <button 
            class="upload-all-btn" 
            bindtap="uploadAll" 
            disabled="{{images.length === 0 || uploading}}"
      >
            {{uploading ? '上传中...' : '批量上传'}}
      </button>

      <view class="log-section" wx:if="{{logs.length > 0}}">
            <text class="log-title">上传日志</text>
            <view class="log-list">
                  <view class="log-item" wx:for="{{logs}}" wx:key="index">
                        <text class="log-key">{{item.key}}</text>
                        <text class="log-status {{item.success ? 'success' : 'fail'}}">
                              {{item.success ? '成功' : '失败'}}
                        </text>
                  </view>
            </view>
      </view>
</view>
