/* ==================== 启动页 - 科技感主题 ==================== */
page {
      background: #0a0f1a;
}

.contain {
      width: 100%;
      height: 100vh;
      position: relative;
      background: linear-gradient(135deg, #0a0f1a 0%, #1a1f2e 50%, #0d1320 100%);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
}

.bg {
      position: absolute;
      left: 0rpx;
      top: 0rpx;
      width: 100%;
      height: 100%;
      z-index: 0;
      opacity: 0.3;
}

/* 科技感网格背景 */
.contain::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      background: 
            linear-gradient(90deg, transparent 49%, rgba(0, 212, 255, 0.02) 50%, transparent 51%),
            linear-gradient(0deg, transparent 49%, rgba(0, 212, 255, 0.02) 50%, transparent 51%);
      background-size: 60rpx 60rpx;
      z-index: 1;
      pointer-events: none;
}

/* Logo 和标题容器 */
.content {
      position: relative;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
}

.logo {
      width: 180rpx;
      height: 180rpx;
      border-radius: 40rpx;
      box-shadow: 
            0 0 40rpx rgba(0, 212, 255, 0.3),
            0 8rpx 32rpx rgba(0, 0, 0, 0.5);
      border: 3rpx solid rgba(0, 212, 255, 0.3);
      margin-bottom: 40rpx;
}

.app-name {
      font-size: 48rpx;
      font-weight: 700;
      color: rgba(255, 255, 255, 0.95);
      letter-spacing: 6rpx;
      margin-bottom: 16rpx;
}

.app-slogan {
      font-size: 28rpx;
      color: rgba(255, 255, 255, 0.5);
      letter-spacing: 4rpx;
}

/* 跳过按钮 - 左上角，低调样式 */
.skip-btn {
      position: absolute;
      left: 32rpx;
      top: calc(80rpx + env(safe-area-inset-top));
      z-index: 10;
      padding: 12rpx 20rpx;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 24rpx;
}

.skip-btn text {
      font-size: 24rpx;
      color: rgba(255, 255, 255, 0.35);
      letter-spacing: 0.5rpx;
}

.skip-btn:active {
      background: rgba(255, 255, 255, 0.1);
}

.skip-btn:active text {
      color: rgba(255, 255, 255, 0.5);
}

/* 加载动画 */
.loading {
      position: absolute;
      bottom: 200rpx;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
}

.loading-text {
      font-size: 26rpx;
      color: rgba(255, 255, 255, 0.4);
      letter-spacing: 2rpx;
      animation: pulse 2s infinite;
}

@keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
}
