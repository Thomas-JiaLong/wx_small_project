<wxs src="../../common.wxs" module="morejs" />

<!-- 顶部搜索栏 -->
<view class="header">
      <view class="search-box" bindtap="search">
            <image class="search-icon" src="/images/search.png"></image>
            <text class="search-placeholder">搜索想要的书籍...</text>
      </view>
      <view class="view-toggle" bindtap="changeCard">
            <image src="{{iscard ? '/images/list.png' : '/images/card.png'}}"></image>
      </view>
</view>

<!-- 轮播图 -->
<swiper 
      class="banner" 
      indicator-dots 
      autoplay 
      indicator-active-color="#667eea" 
      circular
      duration="500"
>
      <swiper-item wx:for="{{banner}}" wx:key="id">
            <image 
                  mode="aspectFill" 
                  lazy-load 
                  src="{{item.img}}" 
                  class="banner-image"
            />
      </swiper-item>
</swiper>

<!-- 分类导航 -->
<view class="category-section">
      <view class="category-header">
            <view class="category-scroll">
                  <view 
                        class="category-item {{collegeCur === -2 ? 'active' : ''}}" 
                        bindtap="selectAll"
                  >
                        <text>全部</text>
                  </view>
                  <view 
                        class="category-item {{index === collegeCur ? 'active' : ''}}" 
                        wx:for="{{college}}" 
                        wx:key="id" 
                        bindtap="collegeSelect" 
                        data-id="{{index}}"
                  >
                        <text>{{item.name}}</text>
                  </view>
            </view>
            <view class="category-more" bindtap="showlist">
                  <image src="{{showList ? '/images/l_down.png' : '/images/l_right.png'}}" />
            </view>
      </view>
      
      <!-- 展开的分类面板 -->
      <view class="category-panel {{showList ? 'show' : ''}}">
            <view class="category-grid">
                  <view 
                        class="grid-item {{index === collegeCur ? 'active' : ''}}" 
                        wx:for="{{college}}" 
                        wx:key="id" 
                        bindtap="collegeSelect" 
                        data-id="{{index}}"
                  >
                        <text>{{item.name}}</text>
                  </view>
            </view>
      </view>
</view>

<!-- 书籍列表 - 卡片模式 -->
<view class="book-section" wx:if="{{iscard}}">
      <view class="book-grid" wx:if="{{list.length > 0}}">
            <view 
                  class="book-card" 
                  wx:for="{{list}}" 
                  wx:key="_id" 
                  bindtap="detail" 
                  data-id="{{item._id}}"
            >
                  <image 
                        class="book-cover" 
                        src="{{item.bookinfo.pic}}" 
                        mode="aspectFill"
                        lazy-load
                  ></image>
                  <view class="book-info">
                        <view class="book-title text-cut-2">{{item.bookinfo.title}}</view>
                        <view class="book-author text-cut">{{item.bookinfo.author}}</view>
                        <view class="book-bottom">
                              <text class="book-price">¥{{item.price}}</text>
                              <image class="buy-icon" src="/images/buy.png"></image>
                        </view>
                  </view>
            </view>
      </view>
</view>

<!-- 书籍列表 - 列表模式 -->
<view class="book-section" wx:else>
      <view class="book-list" wx:if="{{list.length > 0}}">
            <view 
                  class="list-item" 
                  wx:for="{{list}}" 
                  wx:key="_id" 
                  bindtap="detail" 
                  data-id="{{item._id}}"
            >
                  <image 
                        class="list-cover" 
                        src="{{item.bookinfo.pic}}" 
                        mode="aspectFill"
                        lazy-load
                  ></image>
                  <view class="list-info">
                        <view class="list-title text-cut">{{item.bookinfo.title}}</view>
                        <view class="list-author text-cut">{{item.bookinfo.author}}</view>
                        <view class="list-bottom">
                              <text class="list-price">¥{{item.price}}</text>
                              <text class="list-time">{{morejs.timelog(item.creat)}}</text>
                        </view>
                  </view>
            </view>
      </view>
</view>

<!-- 空状态 -->
<view class="empty-state" wx:if="{{list.length === 0}}">
      <image src="/images/blank.png"></image>
      <text>暂无书籍，换个分类看看~</text>
</view>

<!-- 加载更多 -->
<view class="loadmore" wx:if="{{list.length > 10 && !nomore}}">
      <image src="/images/loading.png"></image>
      <view>加载中...</view>
</view>
<view class="loadmore" wx:if="{{nomore && list.length > 0}}">
      <view>— 已经到底了 —</view>
</view>

<!-- 回到顶部 -->
<view class="totop" wx:if="{{scrollTop > 500}}" bindtap="gotop">
      <image src="/images/top.png"></image>
</view>

<!-- 首次提示 -->
<tips />
