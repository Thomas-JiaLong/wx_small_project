/* ==================== 搜索栏 ==================== */
.search-header {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  background: linear-gradient(180deg, #0d1320 0%, #0a0f1a 100%);
  border-bottom: 1rpx solid rgba(0, 212, 255, 0.1);
  gap: 20rpx;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  height: 76rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 38rpx;
  padding: 0 28rpx;
  border: 1rpx solid rgba(0, 212, 255, 0.12);
}

.search-icon {
  width: 34rpx;
  height: 34rpx;
  opacity: 0.6;
  flex-shrink: 0;
}

.search-text {
  margin-left: 16rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.35);
}

.layout-toggle {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.layout-toggle image {
  width: 38rpx;
  height: 38rpx;
  opacity: 0.7;
}

/* ==================== 分类导航 ==================== */
.nav-placeholder {
  height: 88rpx;
}

.category-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #0d1320;
  border-bottom: 1rpx solid rgba(0, 212, 255, 0.08);
  display: flex;
  align-items: center;
  padding: 0 8rpx;
  margin-top: 124rpx;
}

.nav-scroll {
  flex: 1;
  white-space: nowrap;
}

.nav-item {
  display: inline-flex;
  padding: 24rpx 20rpx;
}

.nav-text {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.5);
  position: relative;
  transition: all 0.3s ease;
}

.nav-text.active {
  color: #00d4ff;
  font-weight: 600;
}

.nav-text.active::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 36rpx;
  height: 4rpx;
  background: #00d4ff;
  border-radius: 2rpx;
}

.nav-more {
  width: 72rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-left: 1rpx solid rgba(0, 212, 255, 0.08);
}

.nav-more image {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.5;
}

/* 分类面板 */
.category-panel {
  position: absolute;
  top: 88rpx;
  left: 0;
  right: 0;
  background: #0d1320;
  border-radius: 0 0 24rpx 24rpx;
  padding: 24rpx;
  max-height: 0;
  overflow: hidden;
  transition: all 0.3s ease;
  z-index: 200;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.5);
}

.category-panel.show {
  max-height: 600rpx;
  padding: 24rpx;
}

.panel-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.panel-item {
  width: calc(25% - 12rpx);
  height: 68rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  border: 1rpx solid rgba(0, 212, 255, 0.08);
  transition: all 0.3s ease;
}

.panel-item.active {
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.2) 0%, rgba(0, 153, 204, 0.2) 100%);
  color: #00d4ff;
  border-color: #00d4ff;
}

/* 遮罩层 */
.overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 90;
}

/* ==================== 宫格布局 ==================== */
.card-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx 20rpx;
  gap: 16rpx;
}

.card-item {
  width: calc(50% - 8rpx);
  background: #0d1320;
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid rgba(0, 212, 255, 0.06);
  transition: all 0.2s ease;
}

.card-item:active {
  transform: scale(0.98);
  border-color: rgba(0, 212, 255, 0.2);
}

.card-cover {
  width: 100%;
  height: 320rpx;
  background: rgba(255, 255, 255, 0.03);
}

.card-info {
  padding: 20rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.4;
  min-height: 80rpx;
}

.card-author {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 8rpx;
}

.card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.card-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #00d4ff;
}

.card-buy {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.7;
}

/* ==================== 列表布局 ==================== */
.list-container {
  padding: 12rpx 20rpx;
}

.list-item {
  display: flex;
  background: #0d1320;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(0, 212, 255, 0.06);
  transition: all 0.2s ease;
}

.list-item:active {
  transform: scale(0.99);
  border-color: rgba(0, 212, 255, 0.2);
}

.list-cover {
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.03);
}

.list-info {
  flex: 1;
  padding: 16rpx 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.list-title {
  font-size: 30rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.9);
}

.list-author {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 6rpx;
}

.list-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(0, 212, 255, 0.06);
}

.list-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #00d4ff;
}

.list-time {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.35);
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-state image {
  width: 280rpx;
  height: 220rpx;
  opacity: 0.4;
}

.empty-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* ==================== 加载状态 ==================== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(0, 212, 255, 0.2);
  border-top-color: #00d4ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-spinner.small {
  width: 36rpx;
  height: 36rpx;
  border-width: 3rpx;
}

.loading-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ==================== 加载更多 ==================== */
.loadmore {
  text-align: center;
  padding: 32rpx;
  color: rgba(255, 255, 255, 0.35);
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.loadmore-text {
  display: inline;
}

/* ==================== 回到顶部 ==================== */
.back-top {
  position: fixed;
  right: 32rpx;
  bottom: 200rpx;
  width: 84rpx;
  height: 84rpx;
  background: rgba(0, 212, 255, 0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(0, 212, 255, 0.3);
  opacity: 0;
  transform: scale(0.6);
  transition: all 0.3s ease;
  pointer-events: none;
}

.back-top.show {
  opacity: 1;
  transform: scale(1);
  pointer-events: auto;
}

.back-top image {
  width: 40rpx;
  height: 40rpx;
}

/* ==================== 轮播图 ==================== */
.banner {
  width: 100%;
  height: 320rpx;
}

.banner image {
  width: 100%;
  height: 100%;
}
