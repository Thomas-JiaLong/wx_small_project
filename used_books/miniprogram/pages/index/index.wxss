/* ==================== йҰ–йЎөж ·ејҸ - з§‘жҠҖж„ҹдё»йўҳ ==================== */

/* йҡҗи—Ҹж»ҡеҠЁжқЎ */
::-webkit-scrollbar {
      width: 0;
      height: 0;
      color: transparent;
}

/* йЎ¶йғЁжҗңзҙўж Ҹ */
.top_box {
      width: 100%;
      background: linear-gradient(135deg, #0d1320 0%, #1a1f2e 100%);
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 28rpx 32rpx;
      box-sizing: border-box;
      border-bottom: 1rpx solid rgba(0, 212, 255, 0.12);
}

.top_list {
      width: 48rpx;
      height: 48rpx;
      /* еӣҫж ҮйўңиүІз»ҹдёҖдёәйқ’иүІ */
      filter: brightness(0) saturate(100%) invert(85%) sepia(56%) saturate(3132%) hue-rotate(152deg) brightness(99%) contrast(101%);
      opacity: 0.9;
}

.search_box {
      width: 600rpx;
      height: 76rpx;
      border-radius: 38rpx;
      background: rgba(255, 255, 255, 0.05);
      display: flex;
      align-items: center;
      border: 1rpx solid rgba(0, 212, 255, 0.2);
      transition: border-color 0.2s ease, background 0.2s ease;
      will-change: auto;
}

.search_box:active {
      border-color: #00d4ff;
      background: rgba(0, 212, 255, 0.08);
}

.search_ico {
      padding-left: 32rpx;
      width: 36rpx;
      height: 36rpx;
      /* еӣҫж ҮйўңиүІз»ҹдёҖдёәйқ’иүІ */
      filter: brightness(0) saturate(100%) invert(85%) sepia(56%) saturate(3132%) hue-rotate(152deg) brightness(99%) contrast(101%);
      opacity: 0.9;
}

.search_text {
      padding-left: 16rpx;
      font-size: 28rpx;
      letter-spacing: 1rpx;
      color: rgba(255, 255, 255, 0.4);
}

/* ==================== еҲҶзұ»еҜјиҲӘ ==================== */
.kind_contain {
      width: 100%;
      height: 96rpx;
      display: flex;
      border-bottom: 1rpx solid rgba(0, 212, 255, 0.1);
      background: #0d1320;
      align-items: center;
      position: relative;
      z-index: 50;
}

.nav {
      width: calc(100% - 160rpx);
      height: 100%;
      white-space: nowrap;
      display: flex;
      box-sizing: border-box;
}

.nav-item {
      width: 100rpx;
      height: 100%;
      display: inline-block;
      font-size: 30rpx;
}

.nav-text {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      letter-spacing: 2rpx;
      box-sizing: border-box;
      color: rgba(255, 255, 255, 0.6);
      transition: color 0.2s ease;
      background: transparent;
}

.nav-text:active {
      background: rgba(0, 212, 255, 0.05);
}

.tab-on {
      color: #00d4ff !important;
      font-size: 32rpx !important;
      font-weight: 600;
      border-bottom: 4rpx solid #00d4ff !important;
      background: transparent;
}

.kind_img {
      width: 72rpx;
      height: 72rpx;
      display: flex;
      justify-content: center;
      align-items: center;
}

.kind_img image {
      width: 32rpx;
      height: 32rpx;
      filter: brightness(0) saturate(100%) invert(85%) sepia(56%) saturate(3132%) hue-rotate(152deg) brightness(99%) contrast(101%);
      opacity: 0.9;
}

/* еұ•ејҖзҡ„еҲҶзұ»йқўжқҝ */
.kindlist_box {
      position: absolute;
      width: 100%;
      top: 96rpx;
      left: 0;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
      z-index: 100;
      background: #0d1320;
      border-bottom: 1rpx solid rgba(0, 212, 255, 0.15);
}

.kindlist_box.show {
      max-height: 600rpx;
}

.kindlist_card {
      padding: 24rpx;
      width: 100%;
      display: flex;
      box-sizing: border-box;
      background: #0d1320;
}

.list_grid {
      width: 100%;
      display: flex;
      flex-wrap: wrap;
}

.list_one {
      width: 25%;
      padding: 8rpx;
      display: flex;
      box-sizing: border-box;
}

.list_one view {
      width: 100%;
      height: 64rpx;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1rpx solid rgba(0, 212, 255, 0.2);
      border-radius: 12rpx;
      font-size: 26rpx;
      letter-spacing: 1rpx;
      color: rgba(255, 255, 255, 0.7);
      background: rgba(255, 255, 255, 0.03);
      transition: all 0.2s ease;
}

.list_one view:active {
      background: rgba(0, 212, 255, 0.1);
      border-color: rgba(0, 212, 255, 0.4);
}

.list-on {
      background: linear-gradient(135deg, #00d4ff 0%, #0099cc 100%) !important;
      color: #fff !important;
      border: none !important;
      box-shadow: 0 4rpx 16rpx rgba(0, 212, 255, 0.35);
}

/* йҒ®зҪ©еұӮ */
.overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.7);
      z-index: 40;
}

/* ==================== еҚЎзүҮзҪ‘ж јеёғеұҖ ==================== */
.card_grid {
      width: 100%;
      display: flex;
      box-sizing: border-box;
      padding: 20rpx 24rpx;
      flex-wrap: wrap;
      gap: 20rpx;
      background: #0a0f1a;
}

.card_one {
      width: calc(50% - 10rpx);
      padding: 24rpx;
      display: flex;
      box-sizing: border-box;
      flex-direction: column;
      align-items: center;
      background: #0d1320;
      border-radius: 20rpx;
      border: 1rpx solid rgba(0, 212, 255, 0.1);
}

.card_one:active {
      background: rgba(0, 212, 255, 0.08);
      border-color: rgba(0, 212, 255, 0.3);
}

.card_poster {
      width: 240rpx;
      height: 240rpx;
      border-radius: 16rpx;
      box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.5);
}

.card_title {
      width: 100%;
      font-size: 30rpx;
      letter-spacing: 1rpx;
      margin-top: 20rpx;
      line-height: 42rpx;
      color: rgba(255, 255, 255, 0.95);
      text-align: center;
}

.card_author {
      width: 100%;
      font-size: 26rpx;
      letter-spacing: 1rpx;
      line-height: 38rpx;
      color: rgba(255, 255, 255, 0.5);
      text-align: center;
}

.card_between {
      margin-top: 12rpx;
      width: 100%;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
}

.card_price {
      font-size: 34rpx;
      color: #00d4ff;
      font-weight: 600;
}

.card_buy {
      width: 40rpx;
      height: 40rpx;
      filter: brightness(0) saturate(100%) invert(85%) sepia(56%) saturate(3132%) hue-rotate(152deg) brightness(99%) contrast(101%);
      opacity: 0.8;
}

/* ==================== еҲ—иЎЁеёғеұҖ ==================== */
.list_box {
      width: calc(100% - 48rpx);
      display: flex;
      align-items: center;
      padding: 24rpx;
      box-sizing: border-box;
      margin: 16rpx auto;
      background: #0d1320;
      border-radius: 20rpx;
      border: 1rpx solid rgba(0, 212, 255, 0.1);
}

.list_box:active {
      background: rgba(0, 212, 255, 0.08);
      border-color: rgba(0, 212, 255, 0.3);
}

.list_poster {
      width: 180rpx;
      height: 180rpx;
      border-radius: 16rpx;
      box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.4);
}

.list_content {
      height: 180rpx;
      width: calc(100% - 200rpx);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 0 20rpx;
      box-sizing: border-box;
}

.list_word {
      display: flex;
      flex-direction: column;
      width: 100%;
      box-sizing: border-box;
}

.list_title {
      width: 100%;
      font-size: 32rpx;
      letter-spacing: 1rpx;
      line-height: 44rpx;
      color: rgba(255, 255, 255, 0.95);
}

.list_author {
      padding-top: 8rpx;
      width: 100%;
      font-size: 26rpx;
      letter-spacing: 1rpx;
      line-height: 38rpx;
      color: rgba(255, 255, 255, 0.5);
}

.list_between {
      width: 100%;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      padding-bottom: 4rpx;
}

.list_price {
      font-size: 36rpx;
      color: #00d4ff;
      font-weight: 600;
}

.list_time {
      font-size: 24rpx;
      letter-spacing: 1rpx;
      color: rgba(255, 255, 255, 0.4);
}

/* ==================== з©әзҠ¶жҖҒ ==================== */
.nocontent {
      width: 100%;
      min-height: 60vh;
      display: flex;
      justify-content: center;
      align-items: center;
      flex-direction: column;
      box-sizing: border-box;
      padding: 100rpx 40rpx;
      background: #0a0f1a;
}

.nocontent image {
      width: 300rpx;
      height: 240rpx;
      opacity: 0.5;
      filter: grayscale(30%);
}

.blank_text {
      padding-top: 32rpx;
      font-size: 30rpx;
      letter-spacing: 1rpx;
      color: rgba(255, 255, 255, 0.4);
      text-align: center;
}

/* ==================== еӣһеҲ°йЎ¶йғЁ ==================== */
.totop {
      position: fixed;
      right: 32rpx;
      bottom: 200rpx;
      width: 88rpx;
      height: 88rpx;
      background: rgba(0, 212, 255, 0.15);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1rpx solid rgba(0, 212, 255, 0.3);
      backdrop-filter: blur(10px);
}

.totop image {
      width: 44rpx;
      height: 44rpx;
      filter: brightness(0) saturate(100%) invert(85%) sepia(56%) saturate(3132%) hue-rotate(152deg) brightness(99%) contrast(101%);
}

/* ==================== еӣәе®ҡе®ҡдҪҚ ==================== */
.fixed {
      position: fixed;
      left: 0rpx;
      top: 0rpx;
      z-index: 50;
}

.nofixed {
      height: 97rpx;
      width: 100%;
      background: #0d1320;
}
/* ==================== ҙ°ҝЪдЦИҫ¶Ҝ»ӯ ==================== */
.show {
      transition: opacity 0.3s ease, transform 0.3s ease;
}

.hide {
      transition: opacity 0.3s ease;
}

/* ==================== јУФШЧҙМ¬ ==================== */
.loading_box {
      width: 100%;
      padding: 32rpx 0;
      display: flex;
      justify-content: center;
      align-items: center;
}

.loading_text {
      font-size: 28rpx;
      color: rgba(0, 212, 255, 0.7);
      letter-spacing: 2rpx;
}

/* ==================== ·ЦТіјУФШМбКҫ ==================== */
.loadmore_tip {
      width: 100%;
      padding: 32rpx 0 64rpx;
      display: flex;
      justify-content: center;
      align-items: center;
}

.loadmore_tip text {
      font-size: 26rpx;
      color: rgba(255, 255, 255, 0.3);
      letter-spacing: 2rpx;
}
