/* ==================== 顶部搜索栏 ==================== */
.header {
      background: var(--primary-gradient);
      display: flex;
      align-items: center;
      padding: 24rpx 32rpx;
      gap: 20rpx;
}

.search-box {
      flex: 1;
      height: 76rpx;
      background: rgba(255, 255, 255, 0.95);
      border-radius: 38rpx;
      display: flex;
      align-items: center;
      padding: 0 32rpx;
      box-shadow: var(--shadow-sm);
}

.search-icon {
      width: 36rpx;
      height: 36rpx;
      opacity: 0.5;
}

.search-placeholder {
      margin-left: 16rpx;
      font-size: 28rpx;
      color: var(--text-placeholder);
      letter-spacing: 1rpx;
}

.view-toggle {
      width: 64rpx;
      height: 64rpx;
      background: rgba(255, 255, 255, 0.2);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
}

.view-toggle image {
      width: 40rpx;
      height: 40rpx;
}

/* ==================== 轮播图 ==================== */
.banner {
      width: 100%;
      height: 320rpx;
      background: var(--primary-gradient);
}

.banner-image {
      width: calc(100% - 32rpx);
      height: 100%;
      margin: 16rpx 16rpx 16rpx 16rpx;
      border-radius: var(--border-radius-lg);
      box-shadow: var(--shadow-md);
}

/* ==================== 分类导航 ==================== */
.category-section {
      background: var(--bg-card);
      position: relative;
      z-index: 10;
}

.category-header {
      display: flex;
      align-items: center;
      border-bottom: 1rpx solid var(--border-color);
}

.category-scroll {
      flex: 1;
      display: flex;
      overflow-x: auto;
      white-space: nowrap;
      padding: 0 16rpx;
      scrollbar-width: none;
}

.category-scroll::-webkit-scrollbar {
      display: none;
}

.category-item {
      padding: 28rpx 24rpx;
      font-size: 30rpx;
      color: var(--text-secondary);
      position: relative;
      transition: all 0.3s ease;
}

.category-item.active {
      color: var(--primary-color);
      font-weight: 600;
}

.category-item.active::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 40rpx;
      height: 6rpx;
      background: var(--primary-gradient);
      border-radius: 3rpx;
}

.category-more {
      width: 80rpx;
      height: 88rpx;
      display: flex;
      align-items: center;
      justify-content: center;
      border-left: 1rpx solid var(--border-color);
}

.category-more image {
      width: 32rpx;
      height: 32rpx;
      opacity: 0.5;
}

/* 分类面板 */
.category-panel {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
      background: var(--bg-page);
}

.category-panel.show {
      max-height: 600rpx;
      padding: 24rpx;
}

.category-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 16rpx;
}

.grid-item {
      width: calc(25% - 12rpx);
      height: 72rpx;
      background: var(--bg-card);
      border-radius: var(--border-radius);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 28rpx;
      color: var(--text-secondary);
      border: 1rpx solid var(--border-color);
      transition: all 0.3s ease;
}

.grid-item.active {
      background: var(--primary-gradient);
      color: #fff;
      border-color: transparent;
}

/* ==================== 书籍网格 ==================== */
.book-section {
      padding: 20rpx 16rpx;
}

.book-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 16rpx;
}

.book-card {
      width: calc(50% - 8rpx);
      background: var(--bg-card);
      border-radius: var(--border-radius-lg);
      overflow: hidden;
      box-shadow: var(--shadow-sm);
      transition: all 0.3s ease;
}

.book-card:active {
      transform: scale(0.98);
      box-shadow: var(--shadow-md);
}

.book-cover {
      width: 100%;
      height: 320rpx;
      background: var(--bg-input);
}

.book-info {
      padding: 20rpx;
}

.book-title {
      font-size: 30rpx;
      font-weight: 500;
      color: var(--text-primary);
      line-height: 1.4;
      min-height: 84rpx;
}

.book-author {
      font-size: 26rpx;
      color: var(--text-placeholder);
      margin-top: 8rpx;
}

.book-bottom {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: 16rpx;
}

.book-price {
      font-size: 36rpx;
      font-weight: 600;
      color: var(--error-color);
}

.buy-icon {
      width: 44rpx;
      height: 44rpx;
      opacity: 0.8;
}

/* ==================== 书籍列表 ==================== */
.book-list {
      display: flex;
      flex-direction: column;
      gap: 16rpx;
}

.list-item {
      display: flex;
      background: var(--bg-card);
      border-radius: var(--border-radius-lg);
      overflow: hidden;
      box-shadow: var(--shadow-sm);
      transition: all 0.3s ease;
}

.list-item:active {
      transform: scale(0.99);
}

.list-cover {
      width: 200rpx;
      height: 200rpx;
      background: var(--bg-input);
      flex-shrink: 0;
}

.list-info {
      flex: 1;
      padding: 20rpx 24rpx;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
}

.list-title {
      font-size: 32rpx;
      font-weight: 500;
      color: var(--text-primary);
}

.list-author {
      font-size: 28rpx;
      color: var(--text-placeholder);
      margin-top: 8rpx;
}

.list-bottom {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 16rpx;
      border-top: 1rpx solid var(--border-color);
}

.list-price {
      font-size: 36rpx;
      font-weight: 600;
      color: var(--error-color);
}

.list-time {
      font-size: 26rpx;
      color: var(--text-placeholder);
}

/* ==================== 空状态 ==================== */
.empty-state {
      padding: 120rpx 0;
}
