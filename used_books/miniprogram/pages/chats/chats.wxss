/* 消息列表页样式 - 科技感主题 */
page {
  background: #0a0f1a;
}

.page-container {
  min-height: 100vh;
  background: #0a0f1a;
}

/* 标题栏 */
.header {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: #0d1320;
  border-bottom: 1rpx solid rgba(0, 212, 255, 0.1);
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.95);
  letter-spacing: 2rpx;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 300rpx;
}

/* 会话列表 */
.conversation-list {
  padding: 16rpx 0;
}

.conversation-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #0d1320;
  border-bottom: 1rpx solid rgba(0, 212, 255, 0.05);
  transition: background 0.2s ease;
}

.conversation-item:active {
  background: #1a1f2e;
}

/* 头像容器 */
.avatar-wrapper {
  position: relative;
  margin-right: 24rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #1a1f2e;
  flex-shrink: 0;
}

/* 未读红点 */
.unread-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: #ff4757;
  border-radius: 18rpx;
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  box-sizing: border-box;
}

/* 内容区域 */
.content {
  flex: 1;
  overflow: hidden;
}

.top-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.name {
  font-size: 30rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.95);
  letter-spacing: 1rpx;
}

.time {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 书籍提示 */
.book-tip {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 165, 0, 0.8);
}

.book-icon {
  margin-right: 6rpx;
  font-size: 24rpx;
}

.book-title {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 300rpx;
}

/* 最后消息 */
.bottom-row {
  display: flex;
  align-items: center;
}

.last-msg {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  max-width: 100%;
}

.text-cut {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.5;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* 登录按钮 */
.login-btn {
  margin-top: 32rpx;
  padding: 0 48rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #00d4ff 0%, #0099cc 100%);
  border: none;
  border-radius: 40rpx;
  color: #0a0f1a;
  font-size: 28rpx;
  font-weight: 600;
}

.login-btn::after {
  border: none;
}
