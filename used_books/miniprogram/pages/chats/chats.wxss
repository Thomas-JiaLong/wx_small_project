.container {
  min-height: 100vh;
  background: var(--bg-page);
}

.header {
  background: var(--primary-gradient);
  padding: 40rpx 30rpx;
  text-align: center;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.loading {
  padding: 100rpx;
  text-align: center;
  color: var(--text-placeholder);
}

.empty {
  padding: 200rpx 100rpx;
  text-align: center;
  color: var(--text-placeholder);
  font-size: 28rpx;
}

.tip {
  display: block;
  margin-top: 20rpx;
  color: var(--primary-color);
}

.list {
  background: var(--bg-card);
  margin-top: -20rpx;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
}

.item {
  display: flex;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--border-color);
  transition: background 0.2s ease;
}

.item:active {
  background: var(--bg-input);
}

.item:last-child {
  border-bottom: none;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  flex-shrink: 0;
  box-shadow: var(--shadow-sm);
}

.content {
  flex: 1;
  overflow: hidden;
}

.top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.name {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.time {
  font-size: 24rpx;
  color: var(--text-placeholder);
}

.bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.msg {
  font-size: 28rpx;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 400rpx;
}

.badge {
  background: var(--error-color);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  min-width: 36rpx;
  text-align: center;
  font-weight: 500;
}
