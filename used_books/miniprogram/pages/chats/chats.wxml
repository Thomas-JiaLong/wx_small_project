<view class="container">
  <!-- 标题栏 -->
  <view class="header">
    <text class="title">消息</text>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <!-- 未登录提示 -->
  <view wx:elif="{{!app.openid}}" class="empty">
    <text>登录后查看消息</text>
  </view>

  <!-- 会话列表 -->
  <view wx:elif="{{conversations.length > 0}}" class="list">
    <view 
      wx:for="{{conversations}}" 
      wx:key="_id"
      class="item"
      bindtap="goChat"
      data-id="{{item._id}}"
      data-name="{{item.name}}"
      data-avatar="{{item.avatar}}"
    >
      <image 
        class="avatar" 
        src="{{item.avatar || '/images/default_avatar.png'}}" 
        mode="aspectFill"
        bindtap="previewAvatar"
        data-avatar="{{item.avatar}}"
      ></image>
      <view class="content">
        <view class="top">
          <text class="name">{{item.name}}</text>
          <text class="time">{{item.lastTimeFormat}}</text>
        </view>
        <view class="bottom">
          <text class="msg">{{item.lastMsg}}</text>
          <view wx:if="{{item.unread > 0}}" class="badge">{{item.unread > 99 ? '99+' : item.unread}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:else class="empty">
    <text>暂无消息</text>
    <text class="tip">开始和卖家沟通吧~</text>
  </view>
</view>
