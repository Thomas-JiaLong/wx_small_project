/* ==================== 搜索页 - 科技感统一主题 ==================== */

/* 页面容器 */
page {
      background: #0a0f1a;
      min-height: 100vh;
}

/* 顶部搜索栏 */
.top_contain {
      display: flex;
      align-items: center;
      padding: 24rpx 28rpx;
      background: linear-gradient(135deg, #0d1320 0%, #1a1f2e 100%);
      border-bottom: 1rpx solid rgba(0, 212, 255, 0.12);
      gap: 20rpx;
      position: sticky;
      top: 0;
      z-index: 100;
}

.search_box {
      flex: 1;
      display: flex;
      align-items: center;
      height: 76rpx;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 38rpx;
      padding: 0 24rpx;
      border: 1rpx solid rgba(0, 212, 255, 0.15);
      transition: all 0.3s ease;
}

.search_box:active {
      border-color: #00d4ff;
      background: rgba(0, 212, 255, 0.08);
}

.search_box image {
      width: 36rpx;
      height: 36rpx;
      filter: brightness(0) saturate(100%) invert(85%) sepia(56%) saturate(3132%) hue-rotate(152deg) brightness(99%) contrast(101%);
      opacity: 0.9;
      flex-shrink: 0;
}

.search_box input {
      flex: 1;
      height: 100%;
      margin-left: 16rpx;
      font-size: 30rpx;
      color: rgba(255, 255, 255, 0.95);
      background: transparent;
}

.search_box input::placeholder {
      color: rgba(255, 255, 255, 0.35);
}

.search {
      padding: 18rpx 36rpx;
      background: linear-gradient(135deg, #00d4ff 0%, #0099cc 100%);
      border-radius: 38rpx;
      font-size: 30rpx;
      color: #fff;
      font-weight: 500;
      flex-shrink: 0;
      transition: all 0.2s ease;
}

.search:active {
      opacity: 0.85;
      transform: scale(0.98);
}

/* 内容区域 */
.contain {
      padding: 24rpx;
      background: #0a0f1a;
      min-height: calc(100vh - 130rpx);
}

/* 标题行 - 搜索历史/搜索结果/更多推荐 */
.a {
      display: flex;
      align-items: center;
      gap: 12rpx;
      padding: 24rpx 8rpx 16rpx;
      background: transparent;
}

.a image {
      width: 36rpx;
      height: 36rpx;
      filter: brightness(0) saturate(100%) invert(85%) sepia(56%) saturate(3132%) hue-rotate(152deg) brightness(99%) contrast(101%);
      opacity: 0.8;
      flex-shrink: 0;
}

.a view {
      font-size: 30rpx;
      color: rgba(255, 255, 255, 0.7);
      font-weight: 500;
      background: transparent;
}

/* 无搜索提示 */
.nosearch {
      padding: 40rpx 20rpx;
      font-size: 28rpx;
      color: rgba(255, 255, 255, 0.4);
      text-align: center;
      background: transparent;
}

/* 历史搜索项 */
.hisitem {
      padding: 24rpx 16rpx;
      font-size: 28rpx;
      color: rgba(255, 255, 255, 0.65);
      border-bottom: 1rpx solid rgba(0, 212, 255, 0.08);
      background: transparent;
      transition: all 0.2s ease;
}

.hisitem:active {
      background: rgba(0, 212, 255, 0.05);
      color: #00d4ff;
}

/* 搜索结果列表项 */
.list_box {
      display: flex;
      align-items: center;
      padding: 24rpx;
      background: #0d1320;
      border-radius: 20rpx;
      margin-bottom: 16rpx;
      border: 1rpx solid rgba(0, 212, 255, 0.08);
      transition: all 0.2s ease;
}

.list_box:active {
      background: rgba(0, 212, 255, 0.08);
      border-color: rgba(0, 212, 255, 0.2);
      transform: scale(0.995);
}

.list_poster {
      width: 160rpx;
      height: 160rpx;
      border-radius: 12rpx;
      box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.4);
      flex-shrink: 0;
      background: rgba(255, 255, 255, 0.03);
}

.list_content {
      flex: 1;
      height: 160rpx;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 0 20rpx;
      box-sizing: border-box;
      min-width: 0;
}

.list_word {
      display: flex;
      flex-direction: column;
      gap: 8rpx;
}

.list_title {
      font-size: 30rpx;
      color: rgba(255, 255, 255, 0.95);
      line-height: 1.4;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
}

.list_author {
      font-size: 26rpx;
      color: rgba(255, 255, 255, 0.5);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
}

.list_between {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
}

.list_price {
      font-size: 32rpx;
      color: #00d4ff;
      font-weight: 600;
}

.list_time {
      font-size: 24rpx;
      color: rgba(255, 255, 255, 0.4);
}

/* 空状态 */
.nocontent {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 80rpx 0;
      background: transparent;
}

.nocontent image {
      width: 280rpx;
      height: 220rpx;
      opacity: 0.5;
      filter: grayscale(30%);
}

.blank_text {
      padding-top: 28rpx;
      font-size: 28rpx;
      color: rgba(255, 255, 255, 0.4);
}

/* 回到顶部 */
.totop {
      position: fixed;
      right: 32rpx;
      bottom: 200rpx;
      width: 88rpx;
      height: 88rpx;
      background: rgba(0, 212, 255, 0.15);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1rpx solid rgba(0, 212, 255, 0.3);
      backdrop-filter: blur(10px);
      transition: all 0.2s ease;
}

.totop image {
      width: 44rpx;
      height: 44rpx;
      filter: brightness(0) saturate(100%) invert(85%) sepia(56%) saturate(3132%) hue-rotate(152deg) brightness(99%) contrast(101%);
}

.totop:active {
      background: rgba(0, 212, 255, 0.25);
      transform: scale(0.95);
}

/* 加载更多 */
.loadmore {
      text-align: center;
      padding: 32rpx;
      color: rgba(255, 255, 255, 0.4);
      font-size: 26rpx;
}

.loadmore image {
      width: 40rpx;
      height: 40rpx;
}
