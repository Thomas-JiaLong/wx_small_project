/* ==================== 用户头部 ==================== */
.user-header {
      position: relative;
      padding-bottom: 40rpx;
}

.header-bg {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 260rpx;
      background: var(--primary-gradient);
      border-radius: 0 0 60rpx 60rpx;
}

.user-info {
      position: relative;
      z-index: 10;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 40rpx 40rpx 0;
}

.user-left {
      display: flex;
      flex-direction: column;
      gap: 12rpx;
}

.user-name {
      font-size: 44rpx;
      font-weight: 600;
      color: #fff;
      letter-spacing: 2rpx;
}

.user-tip {
      font-size: 28rpx;
      color: rgba(255, 255, 255, 0.8);
      padding: 8rpx 20rpx;
      background: rgba(255, 255, 255, 0.2);
      border-radius: 20rpx;
      display: inline-flex;
      align-self: flex-start;
}

.user-avatar {
      width: 140rpx;
      height: 140rpx;
      border-radius: 50%;
      overflow: hidden;
      background: #fff;
      box-shadow: var(--shadow-lg);
      display: flex;
      align-items: center;
      justify-content: center;
}

.user-avatar image {
      width: 100%;
      height: 100%;
}

/* ==================== 快捷入口 ==================== */
.quick-actions {
      display: flex;
      justify-content: space-around;
      background: var(--bg-card);
      margin: -20rpx 24rpx 24rpx;
      border-radius: var(--border-radius-lg);
      padding: 32rpx 0;
      box-shadow: var(--shadow-md);
      position: relative;
      z-index: 20;
}

.action-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 16rpx;
}

.action-icon {
      width: 80rpx;
      height: 80rpx;
      background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
}

.action-icon image {
      width: 44rpx;
      height: 44rpx;
}

.action-item text {
      font-size: 26rpx;
      color: var(--text-secondary);
      letter-spacing: 1rpx;
}

/* ==================== 菜单列表 ==================== */
.menu-section {
      padding: 0 24rpx;
}

.menu-card {
      background: var(--bg-card);
      border-radius: var(--border-radius-lg);
      overflow: hidden;
      box-shadow: var(--shadow-sm);
}

.menu-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 32rpx;
      border-bottom: 1rpx solid var(--border-color);
      transition: background 0.2s ease;
}

.menu-item:last-child {
      border-bottom: none;
}

.menu-item:active {
      background: var(--bg-input);
}

.menu-left {
      display: flex;
      align-items: center;
      gap: 24rpx;
}

.menu-icon {
      width: 44rpx;
      height: 44rpx;
}

.menu-left text {
      font-size: 32rpx;
      color: var(--text-primary);
      letter-spacing: 1rpx;
}

.menu-arrow {
      width: 28rpx;
      height: 28rpx;
      opacity: 0.3;
}

/* ==================== 分享弹窗 ==================== */
.share-popup {
      background: var(--bg-card);
      border-radius: 32rpx 32rpx 0 0;
      padding: 40rpx;
}

.share-title {
      text-align: center;
      font-size: 34rpx;
      font-weight: 500;
      color: var(--text-primary);
      margin-bottom: 40rpx;
}

.share-options {
      display: flex;
      justify-content: center;
      gap: 80rpx;
      margin-bottom: 40rpx;
}

.share-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 16rpx;
      position: relative;
}

.share-item image {
      width: 96rpx;
      height: 96rpx;
}

.share-item text {
      font-size: 28rpx;
      color: var(--text-secondary);
}

.share-btn {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      opacity: 0;
}

.share-btn::after {
      border: none;
}

.share-cancel {
      text-align: center;
      padding: 28rpx 0;
      background: var(--bg-input);
      border-radius: var(--border-radius);
      font-size: 32rpx;
      color: var(--text-secondary);
}

/* ==================== 适配旧代码 ==================== */
.avator {
      width: 140rpx;
      height: 140rpx;
      border-radius: 50%;
      overflow: hidden;
}
