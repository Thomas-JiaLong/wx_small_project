/* ==================== 步骤指示器 ==================== */
.step-header {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40rpx 60rpx;
      background: #0d1320;
      border-bottom: 1rpx solid rgba(0, 212, 255, 0.1);
}

.step-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12rpx;
}

.step-num {
      width: 56rpx;
      height: 56rpx;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.05);
      color: rgba(255, 255, 255, 0.4);
      font-size: 28rpx;
      font-weight: 600;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.3s ease;
}

.step-item.active .step-num {
      background: linear-gradient(135deg, #00d4ff 0%, #0099cc 100%);
      color: #fff;
      box-shadow: 0 4rpx 16rpx rgba(0, 212, 255, 0.4);
}

.step-item text {
      font-size: 26rpx;
      color: rgba(255, 255, 255, 0.4);
}

.step-item.active text {
      color: #00d4ff;
      font-weight: 500;
}

.step-line {
      width: 80rpx;
      height: 4rpx;
      background: rgba(0, 212, 255, 0.15);
      margin: 0 16rpx;
      margin-bottom: 40rpx;
      transition: all 0.3s ease;
}

.step-line.active {
      background: linear-gradient(90deg, #00d4ff 0%, #0099cc 100%);
}

/* ==================== 步骤内容 ==================== */
.step-content {
      min-height: calc(100vh - 200rpx);
      padding-bottom: 120rpx;
      background: #0a0f1a;
}

/* ==================== ISBN输入区 ==================== */
.isbn-section {
      padding: 60rpx 40rpx;
      display: flex;
      flex-direction: column;
      align-items: center;
}

.isbn-input-box {
      width: 100%;
      display: flex;
      align-items: center;
      background: #0d1320;
      border-radius: 20rpx;
      padding: 12rpx;
      border: 1rpx solid rgba(0, 212, 255, 0.15);
      margin-bottom: 40rpx;
}

.scan-icon {
      width: 44rpx;
      height: 44rpx;
      margin: 0 20rpx;
      filter: brightness(0) saturate(100%) invert(85%) sepia(56%) saturate(3132%) hue-rotate(152deg) brightness(99%) contrast(101%);
      opacity: 0.9;
}

.isbn-input {
      flex: 1;
      height: 80rpx;
      font-size: 32rpx;
      color: rgba(255, 255, 255, 0.95);
}

.confirm-btn {
      padding: 18rpx 36rpx;
      background: linear-gradient(135deg, #00d4ff 0%, #0099cc 100%);
      color: #fff;
      border-radius: 12rpx;
      font-size: 28rpx;
      font-weight: 500;
}

.isbn-example {
      width: 80%;
      margin-bottom: 40rpx;
      border-radius: 16rpx;
}

.isbn-tip {
      font-size: 28rpx;
      color: rgba(0, 212, 255, 0.6);
      margin-bottom: 32rpx;
      letter-spacing: 1rpx;
      text-align: center;
}

.scan-tip {
      font-size: 28rpx;
      color: rgba(255, 255, 255, 0.4);
      margin-bottom: 32rpx;
}

.scan-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16rpx;
      width: 300rpx;
      height: 88rpx;
      background: #0d1320;
      border-radius: 44rpx;
      border: 1rpx solid rgba(0, 212, 255, 0.2);
}

.scan-btn image {
      width: 40rpx;
      height: 40rpx;
      filter: brightness(0) saturate(100%) invert(85%) sepia(56%) saturate(3132%) hue-rotate(152deg) brightness(99%) contrast(101%);
}

.scan-btn text {
      font-size: 32rpx;
      color: #00d4ff;
      font-weight: 500;
}

.scan-btn::after {
      border: none;
}

/* ==================== 书籍预览 ==================== */
.book-preview {
      display: flex;
      gap: 24rpx;
      padding: 32rpx;
      background: #0d1320;
      margin: 24rpx;
      border-radius: 20rpx;
      border: 1rpx solid rgba(0, 212, 255, 0.1);
}

.preview-cover {
      width: 160rpx;
      height: 200rpx;
      border-radius: 12rpx;
      background: rgba(255, 255, 255, 0.05);
}

.preview-info {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
}

.preview-title {
      font-size: 32rpx;
      font-weight: 600;
      color: rgba(255, 255, 255, 0.95);
}

.preview-author {
      font-size: 28rpx;
      color: rgba(255, 255, 255, 0.5);
}

.preview-price {
      font-size: 28rpx;
      color: rgba(255, 255, 255, 0.4);
}

/* ==================== 发布表单 ==================== */
.publish-form {
      background: #0d1320;
      margin: 24rpx;
      border-radius: 20rpx;
      padding: 8rpx 32rpx;
      border: 1rpx solid rgba(0, 212, 255, 0.1);
}

.form-item {
      padding: 28rpx 0;
      border-bottom: 1rpx solid rgba(0, 212, 255, 0.08);
}

.form-item:last-child {
      border-bottom: none;
}

.form-label {
      font-size: 30rpx;
      color: rgba(255, 255, 255, 0.95);
      font-weight: 500;
      margin-bottom: 20rpx;
}

.optional {
      font-size: 24rpx;
      color: rgba(255, 255, 255, 0.4);
      font-weight: normal;
      margin-left: 8rpx;
}

/* 价格输入 */
.form-control {
      display: flex;
      align-items: center;
      gap: 16rpx;
}

.price-unit {
      font-size: 36rpx;
      color: #00d4ff;
      font-weight: 600;
}

.price-input {
      flex: 1;
      height: 72rpx;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 12rpx;
      padding: 0 24rpx;
      font-size: 36rpx;
      font-weight: 600;
      color: #00d4ff;
}

.price-btns {
      display: flex;
      gap: 16rpx;
}

.price-btn {
      width: 64rpx;
      height: 64rpx;
      background: rgba(0, 212, 255, 0.1);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 40rpx;
      color: #00d4ff;
}

/* 分类标签 */
.category-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 16rpx;
}

.tag {
      padding: 16rpx 32rpx;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 12rpx;
      font-size: 28rpx;
      color: rgba(255, 255, 255, 0.6);
      transition: all 0.3s ease;
}

.tag.active {
      background: linear-gradient(135deg, #00d4ff 0%, #0099cc 100%);
      color: #fff;
}

/* 学院选择 */
.picker-box {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20rpx 24rpx;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 12rpx;
}

.picker-box text {
      font-size: 30rpx;
      color: rgba(255, 255, 255, 0.9);
}

.picker-box image {
      width: 28rpx;
      height: 28rpx;
      filter: brightness(0) saturate(100%) invert(85%) sepia(56%) saturate(3132%) hue-rotate(152deg) brightness(99%) contrast(101%);
      opacity: 0.6;
}

/* 取货方式 */
.delivery-options {
      display: flex;
      gap: 24rpx;
}

.option {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12rpx;
      padding: 24rpx;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 16rpx;
      transition: all 0.3s ease;
}

.option.active {
      background: rgba(0, 212, 255, 0.1);
      border: 2rpx solid #00d4ff;
}

.option image {
      width: 48rpx;
      height: 48rpx;
      filter: brightness(0) saturate(100%) invert(85%) sepia(56%) saturate(3132%) hue-rotate(152deg) brightness(99%) contrast(101%);
      opacity: 0.6;
}

.option.active image {
      opacity: 1;
}

.option text {
      font-size: 28rpx;
      color: rgba(255, 255, 255, 0.6);
}

.option.active text {
      color: #00d4ff;
      font-weight: 500;
}

/* 地址输入 */
.address-input {
      width: 100%;
      height: 72rpx;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 12rpx;
      padding: 0 24rpx;
      font-size: 28rpx;
      color: rgba(255, 255, 255, 0.9);
}

/* 备注输入 */
.note-input {
      width: 100%;
      height: 160rpx;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 12rpx;
      padding: 20rpx;
      font-size: 28rpx;
      line-height: 1.6;
      color: rgba(255, 255, 255, 0.9);
}

.char-count {
      text-align: right;
      font-size: 24rpx;
      color: rgba(255, 255, 255, 0.4);
      margin-top: 8rpx;
}

/* 发布时长 */
.dura-control {
      display: flex;
      align-items: center;
      gap: 24rpx;
}

.dura-btn {
      width: 64rpx;
      height: 64rpx;
      background: rgba(0, 212, 255, 0.1);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 36rpx;
      color: #00d4ff;
}

.dura-value {
      font-size: 48rpx;
      font-weight: 600;
      color: rgba(255, 255, 255, 0.95);
      min-width: 80rpx;
      text-align: center;
}

.dura-unit {
      font-size: 28rpx;
      color: rgba(255, 255, 255, 0.5);
}

.dura-tip {
      font-size: 24rpx;
      color: rgba(255, 255, 255, 0.4);
      margin-top: 16rpx;
      padding: 16rpx;
      background: rgba(0, 212, 255, 0.05);
      border-radius: 12rpx;
}

/* 发布按钮 */
.publish-btn {
      width: calc(100% - 48rpx);
      margin: 32rpx 24rpx;
      height: 96rpx;
      background: linear-gradient(135deg, #00d4ff 0%, #0099cc 100%);
      border-radius: 48rpx;
      font-size: 34rpx;
      font-weight: 500;
      color: #fff;
      letter-spacing: 4rpx;
      box-shadow: 0 8rpx 24rpx rgba(0, 212, 255, 0.35);
      border: none;
}

.publish-btn::after {
      border: none;
}

/* ==================== 成功页面 ==================== */
.success-page {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 120rpx 40rpx;
}

.success-icon {
      width: 200rpx;
      height: 200rpx;
      margin-bottom: 40rpx;
      filter: brightness(0) saturate(100%) invert(85%) sepia(56%) saturate(3132%) hue-rotate(152deg) brightness(99%) contrast(101%);
}

.success-title {
      font-size: 44rpx;
      font-weight: 600;
      color: rgba(255, 255, 255, 0.95);
      margin-bottom: 16rpx;
}

.success-tip {
      font-size: 28rpx;
      color: rgba(255, 255, 255, 0.4);
      margin-bottom: 60rpx;
}

.success-btns {
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: 24rpx;
}

.btn-detail {
      width: 100%;
      height: 96rpx;
      background: linear-gradient(135deg, #00d4ff 0%, #0099cc 100%);
      border-radius: 48rpx;
      font-size: 34rpx;
      color: #fff;
      border: none;
}

.btn-again {
      width: 100%;
      height: 96rpx;
      background: #0d1320;
      border-radius: 48rpx;
      font-size: 34rpx;
      color: #00d4ff;
      border: 2rpx solid rgba(0, 212, 255, 0.3);
}

.btn-detail::after,
.btn-again::after {
      border: none;
}
