/* ==================== 步骤指示器 ==================== */
.step-header {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40rpx 60rpx;
      background: var(--bg-card);
      border-bottom: 1rpx solid var(--border-color);
}

.step-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12rpx;
}

.step-num {
      width: 56rpx;
      height: 56rpx;
      border-radius: 50%;
      background: var(--bg-input);
      color: var(--text-placeholder);
      font-size: 28rpx;
      font-weight: 600;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.3s ease;
}

.step-item.active .step-num {
      background: var(--primary-gradient);
      color: #fff;
      box-shadow: var(--shadow-primary);
}

.step-item text {
      font-size: 26rpx;
      color: var(--text-placeholder);
}

.step-item.active text {
      color: var(--primary-color);
      font-weight: 500;
}

.step-line {
      width: 80rpx;
      height: 4rpx;
      background: var(--border-color);
      margin: 0 16rpx;
      margin-bottom: 40rpx;
      transition: all 0.3s ease;
}

.step-line.active {
      background: var(--primary-gradient);
}

/* ==================== 步骤内容 ==================== */
.step-content {
      min-height: calc(100vh - 200rpx);
      padding-bottom: 120rpx;
}

/* ==================== ISBN输入区 ==================== */
.isbn-section {
      padding: 60rpx 40rpx;
      display: flex;
      flex-direction: column;
      align-items: center;
}

.isbn-input-box {
      width: 100%;
      display: flex;
      align-items: center;
      background: var(--bg-card);
      border-radius: var(--border-radius-lg);
      padding: 8rpx;
      box-shadow: var(--shadow-md);
      margin-bottom: 40rpx;
}

.scan-icon {
      width: 44rpx;
      height: 44rpx;
      margin: 0 20rpx;
      opacity: 0.5;
}

.isbn-input {
      flex: 1;
      height: 80rpx;
      font-size: 32rpx;
}

.confirm-btn {
      padding: 16rpx 32rpx;
      background: var(--primary-gradient);
      color: #fff;
      border-radius: var(--border-radius);
      font-size: 28rpx;
}

.isbn-example {
      width: 80%;
      margin-bottom: 40rpx;
      border-radius: var(--border-radius);
}

.scan-tip {
      font-size: 28rpx;
      color: var(--text-placeholder);
      margin-bottom: 32rpx;
}

.scan-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16rpx;
      width: 300rpx;
      height: 88rpx;
      background: var(--bg-card);
      border-radius: 44rpx;
      box-shadow: var(--shadow-md);
      border: none;
}

.scan-btn image {
      width: 40rpx;
      height: 40rpx;
}

.scan-btn text {
      font-size: 32rpx;
      color: var(--primary-color);
      font-weight: 500;
}

.scan-btn::after {
      border: none;
}

/* ==================== 书籍预览 ==================== */
.book-preview {
      display: flex;
      gap: 24rpx;
      padding: 32rpx;
      background: var(--bg-card);
      margin: 24rpx;
      border-radius: var(--border-radius-lg);
      box-shadow: var(--shadow-sm);
}

.preview-cover {
      width: 160rpx;
      height: 200rpx;
      border-radius: var(--border-radius);
      background: var(--bg-input);
}

.preview-info {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
}

.preview-title {
      font-size: 32rpx;
      font-weight: 600;
      color: var(--text-primary);
}

.preview-author {
      font-size: 28rpx;
      color: var(--text-secondary);
}

.preview-price {
      font-size: 28rpx;
      color: var(--text-placeholder);
}

/* ==================== 发布表单 ==================== */
.publish-form {
      background: var(--bg-card);
      margin: 24rpx;
      border-radius: var(--border-radius-lg);
      padding: 8rpx 32rpx;
}

.form-item {
      padding: 28rpx 0;
      border-bottom: 1rpx solid var(--border-color);
}

.form-item:last-child {
      border-bottom: none;
}

.form-label {
      font-size: 30rpx;
      color: var(--text-primary);
      font-weight: 500;
      margin-bottom: 20rpx;
}

.optional {
      font-size: 24rpx;
      color: var(--text-placeholder);
      font-weight: normal;
      margin-left: 8rpx;
}

/* 价格输入 */
.form-control {
      display: flex;
      align-items: center;
      gap: 16rpx;
}

.price-unit {
      font-size: 36rpx;
      color: var(--error-color);
      font-weight: 600;
}

.price-input {
      flex: 1;
      height: 72rpx;
      background: var(--bg-input);
      border-radius: var(--border-radius);
      padding: 0 24rpx;
      font-size: 36rpx;
      font-weight: 600;
      color: var(--error-color);
}

.price-btns {
      display: flex;
      gap: 16rpx;
}

.price-btn {
      width: 64rpx;
      height: 64rpx;
      background: var(--bg-input);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 40rpx;
      color: var(--primary-color);
}

/* 分类标签 */
.category-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 16rpx;
}

.tag {
      padding: 16rpx 32rpx;
      background: var(--bg-input);
      border-radius: var(--border-radius);
      font-size: 28rpx;
      color: var(--text-secondary);
      transition: all 0.3s ease;
}

.tag.active {
      background: var(--primary-gradient);
      color: #fff;
}

/* 学院选择 */
.picker-box {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20rpx 24rpx;
      background: var(--bg-input);
      border-radius: var(--border-radius);
}

.picker-box text {
      font-size: 30rpx;
      color: var(--text-primary);
}

.picker-box image {
      width: 28rpx;
      height: 28rpx;
      opacity: 0.4;
}

/* 取货方式 */
.delivery-options {
      display: flex;
      gap: 24rpx;
}

.option {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12rpx;
      padding: 24rpx;
      background: var(--bg-input);
      border-radius: var(--border-radius-lg);
      transition: all 0.3s ease;
}

.option.active {
      background: rgba(102, 126, 234, 0.1);
      border: 2rpx solid var(--primary-color);
}

.option image {
      width: 48rpx;
      height: 48rpx;
      opacity: 0.6;
}

.option.active image {
      opacity: 1;
}

.option text {
      font-size: 28rpx;
      color: var(--text-secondary);
}

.option.active text {
      color: var(--primary-color);
      font-weight: 500;
}

/* 地址输入 */
.address-input {
      width: 100%;
      height: 72rpx;
      background: var(--bg-input);
      border-radius: var(--border-radius);
      padding: 0 24rpx;
      font-size: 28rpx;
}

/* 备注输入 */
.note-input {
      width: 100%;
      height: 160rpx;
      background: var(--bg-input);
      border-radius: var(--border-radius);
      padding: 20rpx;
      font-size: 28rpx;
      line-height: 1.6;
}

.char-count {
      text-align: right;
      font-size: 24rpx;
      color: var(--text-placeholder);
      margin-top: 8rpx;
}

/* 发布时长 */
.dura-control {
      display: flex;
      align-items: center;
      gap: 24rpx;
}

.dura-btn {
      width: 64rpx;
      height: 64rpx;
      background: var(--bg-input);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 36rpx;
      color: var(--primary-color);
}

.dura-value {
      font-size: 48rpx;
      font-weight: 600;
      color: var(--text-primary);
      min-width: 80rpx;
      text-align: center;
}

.dura-unit {
      font-size: 28rpx;
      color: var(--text-secondary);
}

.dura-tip {
      font-size: 24rpx;
      color: var(--text-placeholder);
      margin-top: 16rpx;
      padding: 16rpx;
      background: rgba(102, 126, 234, 0.05);
      border-radius: var(--border-radius);
}

/* 发布按钮 */
.publish-btn {
      width: calc(100% - 48rpx);
      margin: 32rpx 24rpx;
      height: 96rpx;
      background: var(--primary-gradient);
      border-radius: 48rpx;
      font-size: 34rpx;
      font-weight: 500;
      color: #fff;
      letter-spacing: 4rpx;
      box-shadow: var(--shadow-primary);
      border: none;
}

.publish-btn::after {
      border: none;
}

/* ==================== 成功页面 ==================== */
.success-page {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 120rpx 40rpx;
}

.success-icon {
      width: 200rpx;
      height: 200rpx;
      margin-bottom: 40rpx;
}

.success-title {
      font-size: 44rpx;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 16rpx;
}

.success-tip {
      font-size: 28rpx;
      color: var(--text-placeholder);
      margin-bottom: 60rpx;
}

.success-btns {
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: 24rpx;
}

.btn-detail {
      width: 100%;
      height: 96rpx;
      background: var(--primary-gradient);
      border-radius: 48rpx;
      font-size: 34rpx;
      color: #fff;
      border: none;
}

.btn-again {
      width: 100%;
      height: 96rpx;
      background: var(--bg-card);
      border-radius: 48rpx;
      font-size: 34rpx;
      color: var(--primary-color);
      border: 2rpx solid var(--primary-color);
}

.btn-detail::after,
.btn-again::after {
      border: none;
}
