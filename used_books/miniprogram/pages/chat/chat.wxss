.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-page);
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: var(--primary-gradient);
}

.back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon {
  font-size: 48rpx;
  color: #fff;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.placeholder {
  width: 60rpx;
}

.message-list {
  flex: 1;
  padding: 20rpx 30rpx;
  box-sizing: border-box;
}

.loading-more {
  text-align: center;
  padding: 20rpx;
  color: var(--text-placeholder);
  font-size: 24rpx;
}

.message-item {
  display: flex;
  margin-bottom: 30rpx;
}

.message-item.self {
  flex-direction: row-reverse;
}

.message-item.other {
  flex-direction: row;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
  border: 4rpx solid #fff;
  box-shadow: var(--shadow-sm);
}

.message-content {
  max-width: 70%;
  margin: 0 20rpx;
}

.message-item.self .message-content {
  align-items: flex-end;
}

.text {
  display: inline-block;
  padding: 20rpx 26rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-all;
}

.message-item.self .text {
  background: var(--primary-gradient);
  color: #fff;
  border-bottom-right-radius: 4rpx;
}

.message-item.other .text {
  background: var(--bg-card);
  color: var(--text-primary);
  border-bottom-left-radius: 4rpx;
  box-shadow: var(--shadow-sm);
}

.image {
  max-width: 300rpx;
  border-radius: 16rpx;
}

.time {
  display: block;
  font-size: 22rpx;
  color: var(--text-placeholder);
  margin-top: 8rpx;
  text-align: center;
}

.empty {
  text-align: center;
  padding: 200rpx 0;
  color: var(--text-placeholder);
  font-size: 28rpx;
}

.input-area {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: var(--bg-card);
  border-top: 1rpx solid var(--border-color);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.input {
  flex: 1;
  height: 76rpx;
  padding: 0 30rpx;
  background: var(--bg-input);
  border-radius: 38rpx;
  font-size: 28rpx;
}

.send-btn {
  margin-left: 20rpx;
  padding: 0 40rpx;
  height: 76rpx;
  line-height: 76rpx;
  background: var(--primary-gradient);
  color: #fff;
  font-size: 28rpx;
  border-radius: 38rpx;
  box-shadow: var(--shadow-primary);
}

.send-btn::after {
  border: none;
}

.send-btn:active {
  transform: scale(0.95);
}
