.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon {
  font-size: 48rpx;
  color: #3498db;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.placeholder {
  width: 60rpx;
}

.message-list {
  flex: 1;
  padding: 20rpx 30rpx;
  box-sizing: border-box;
}

.loading-more {
  text-align: center;
  padding: 20rpx;
  color: #999;
  font-size: 24rpx;
}

.message-item {
  display: flex;
  margin-bottom: 30rpx;
}

.message-item.self {
  flex-direction: row-reverse;
}

.message-item.other {
  flex-direction: row;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.message-content {
  max-width: 70%;
  margin: 0 20rpx;
}

.message-item.self .message-content {
  align-items: flex-end;
}

.text {
  display: inline-block;
  padding: 20rpx 26rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-all;
}

.message-item.self .text {
  background: #3498db;
  color: #fff;
}

.message-item.other .text {
  background: #fff;
  color: #333;
}

.image {
  max-width: 300rpx;
  border-radius: 12rpx;
}

.time {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.empty {
  text-align: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
}

.input-area {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}

.input {
  flex: 1;
  height: 70rpx;
  padding: 0 30rpx;
  background: #f5f5f5;
  border-radius: 35rpx;
  font-size: 28rpx;
}

.send-btn {
  margin-left: 20rpx;
  padding: 0 40rpx;
  height: 70rpx;
  line-height: 70rpx;
  background: #3498db;
  color: #fff;
  font-size: 28rpx;
  border-radius: 35rpx;
}

.send-btn::after {
  border: none;
}
