/* 聊天页面样式 - 科技感主题 */
page {
  height: 100%;
  background: #0a0f1a;
}

.chat-container {
  height: 100%;
  display: flex;
  flex-direction: column;
}

/* 标题栏 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  background: #0d1320;
  border-bottom: 1rpx solid rgba(0, 212, 255, 0.1);
  flex-shrink: 0;
}

.back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back .icon {
  font-size: 48rpx;
  color: #00d4ff;
  font-weight: 300;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.95);
  letter-spacing: 2rpx;
}

.placeholder {
  width: 60rpx;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 24rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

.loading-more {
  text-align: center;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 消息项 */
.message-item {
  display: flex;
  margin-bottom: 32rpx;
  align-items: flex-end;
}

.message-item.self {
  flex-direction: row-reverse;
}

.message-item.other {
  flex-direction: row;
}

/* 头像 */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #1a1f2e;
  flex-shrink: 0;
}

/* 消息内容 */
.message-content {
  max-width: 70%;
  margin: 0 16rpx;
  display: flex;
  flex-direction: column;
}

/* 气泡 */
.bubble {
  padding: 20rpx 28rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-all;
}

.bubble.text.other {
  background: #0d1320;
  color: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(0, 212, 255, 0.1);
  border-top-left-radius: 8rpx;
}

.bubble.text.self {
  background: linear-gradient(135deg, #00d4ff 0%, #0099cc 100%);
  color: #0a0f1a;
  border-top-right-radius: 8rpx;
}

/* 图片气泡 */
.image-bubble {
  max-width: 320rpx;
  border-radius: 12rpx;
  background: #1a1f2e;
}

/* 时间戳 */
.time-stamp {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  margin-top: 8rpx;
  text-align: center;
  padding: 0 8rpx;
}

.message-item.self .time-stamp {
  text-align: right;
}

/* 空状态 */
.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 300rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
  letter-spacing: 2rpx;
}

/* 输入区域 */
.input-area {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #0d1320;
  border-top: 1rpx solid rgba(0, 212, 255, 0.1);
  flex-shrink: 0;
}

.input-box {
  flex: 1;
  background: #1a1f2e;
  border-radius: 40rpx;
  padding: 0 24rpx;
  margin-right: 16rpx;
}

.input {
  height: 72rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.input::placeholder {
  color: rgba(255, 255, 255, 0.4);
}

.action-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.icon-img {
  font-size: 40rpx;
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  background: rgba(0, 212, 255, 0.2);
  border: none;
  border-radius: 36rpx;
  color: rgba(255, 255, 255, 0.5);
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.send-btn.active {
  background: linear-gradient(135deg, #00d4ff 0%, #0099cc 100%);
  color: #0a0f1a;
  font-weight: 600;
}

.send-btn::after {
  border: none;
}
