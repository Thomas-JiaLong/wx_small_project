/* ==================== 发布列表 - 科技感主题 ==================== */

page {
      background: #0a0f1a;
}

.contain {
      width: 100%;
      display: flex;
      box-sizing: border-box;
      flex-direction: column;
      padding: 24rpx;
      background: #0a0f1a;
      min-height: 100vh;
}

.card {
      width: 100%;
      display: flex;
      flex-direction: column;
      padding: 32rpx;
      box-sizing: border-box;
      border-radius: 20rpx;
      margin-bottom: 24rpx;
      background: #0d1320;
      border: 1rpx solid rgba(0, 212, 255, 0.08);
      box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.4);
}

.a {
      width: 100%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1rpx solid rgba(0, 212, 255, 0.08);
      padding-bottom: 24rpx;
}

.a1 {
      font-size: 30rpx;
      letter-spacing: 1rpx;
      display: flex;
      align-items: center;
      color: rgba(255, 255, 255, 0.9);
      font-weight: 500;
}

.text-red {
      color: #ff6b6b;
}

.a1 image {
      width: 36rpx;
      height: 36rpx;
      padding-right: 10rpx;
      filter: brightness(0) saturate(100%) invert(85%) sepia(56%) saturate(3132%) hue-rotate(152deg) brightness(99%) contrast(101%);
}

.a2 {
      font-size: 26rpx;
      color: rgba(255, 255, 255, 0.4);
      letter-spacing: 1rpx;
}

.b {
      width: 100%;
      display: flex;
      align-items: center;
      box-sizing: border-box;
      padding: 24rpx 0;
      border-bottom: 1rpx solid rgba(0, 212, 255, 0.08);
}

.b image {
      width: 140rpx;
      height: 140rpx;
      border-radius: 12rpx;
      box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.4);
}

.b1 {
      width: calc(100% - 160rpx);
      padding: 0 20rpx;
      height: 140rpx;
      display: flex;
      flex-direction: column;
      box-sizing: border-box;
      justify-content: space-between;
}

.b11 {
      display: flex;
      flex-direction: column;
      width: 100%;
}

.b111 {
      font-size: 30rpx;
      letter-spacing: 1rpx;
      color: rgba(255, 255, 255, 0.95);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
}

.b112 {
      padding-top: 10rpx;
      font-size: 26rpx;
      letter-spacing: 1rpx;
      color: rgba(255, 255, 255, 0.5);
}

.b12 {
      display: flex;
      justify-content: flex-end;
      font-size: 34rpx;
      color: #00d4ff;
      font-weight: 600;
}

.c {
      width: 100%;
      display: flex;
      justify-content: flex-end;
      padding-top: 20rpx;
}

.c1 {
      min-width: 120rpx;
      height: 52rpx;
      border-radius: 26rpx;
      display: flex;
      justify-content: center;
      align-items: center;
      font-size: 26rpx;
      letter-spacing: 1rpx;
      margin-left: 20rpx;
      transition: all 0.2s ease;
}

.bg-grey {
      background: rgba(255, 255, 255, 0.08);
      color: rgba(255, 255, 255, 0.6);
      border: 1rpx solid rgba(255, 255, 255, 0.15);
}

.bg-yellow {
      background: linear-gradient(135deg, #00d4ff 0%, #0099cc 100%);
      color: #0d1320;
      font-weight: 500;
      border: none;
}

.c2 {
      min-width: 120rpx;
      height: 52rpx;
      border-radius: 26rpx;
      display: flex;
      justify-content: center;
      align-items: center;
      font-size: 26rpx;
      letter-spacing: 2rpx;
      margin-left: 20rpx;
      background: rgba(255, 107, 107, 0.15);
      color: #ff6b6b;
      border: 1rpx solid rgba(255, 107, 107, 0.3);
      transition: all 0.2s ease;
}

.c2:active {
      background: rgba(255, 107, 107, 0.25);
}

.nocontent {
      width: 100%;
      height: calc(100vh - 200rpx);
      display: flex;
      justify-content: center;
      align-items: center;
      flex-direction: column;
      box-sizing: border-box;
      background: #0a0f1a;
}

.nocontent image {
      padding-left: 80rpx;
      width: 340rpx;
      height: 272rpx;
      opacity: 0.5;
}

.blank_text {
      padding-top: 40rpx;
      font-size: 28rpx;
      letter-spacing: 2rpx;
      color: rgba(255, 255, 255, 0.4);
}
