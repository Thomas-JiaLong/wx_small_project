<wxs src="../../common.wxs" module="morejs" />

<!-- 书籍封面 -->
<view class="book-header">
      <image class="book-cover" src="{{publishinfo.bookinfo.pic}}" mode="aspectFit" lazy-load></image>
</view>

<!-- 价格信息 -->
<view class="price-section">
      <view class="current-price">¥{{publishinfo.price}}</view>
      <view class="original-price">定价 ¥{{publishinfo.bookinfo.price}}</view>
</view>

<!-- 书籍信息 -->
<view class="book-info-card">
      <view class="book-title">{{publishinfo.bookinfo.title}}</view>
      <view class="book-edition">第{{publishinfo.bookinfo.edition}}版</view>
      <view class="book-author">{{publishinfo.bookinfo.author}}</view>
</view>

<!-- 标签切换 -->
<view class="tab-section">
      <view class="tab-header">
            <view class="tab-item {{first_title ? 'active' : ''}}" bindtap="changeTitle" data-id="{{true}}">
                  <text>发布信息</text>
            </view>
            <view class="tab-item {{!first_title ? 'active' : ''}}" bindtap="changeTitle" data-id="{{false}}">
                  <text>图书详情</text>
            </view>
      </view>
      
      <!-- 发布信息 -->
      <view class="tab-content" hidden="{{!first_title}}">
            <!-- 卖家信息 -->
            <view class="seller-card">
                  <image class="seller-avatar" src="{{publisherinfo.info.avatarUrl}}" lazy-load></image>
                  <view class="seller-info">
                        <view class="seller-name">{{publisherinfo.info.nickName}}</view>
                        <view class="seller-campus">
                              <image src="/images/local.png"></image>
                              <text>{{publisherinfo.campus.name}}</text>
                        </view>
                  </view>
                  <view class="seller-gender">
                        <image src="{{publisherinfo.info.gender == 1 ? '/images/boy.png' : '/images/girl.png'}}"></image>
                  </view>
            </view>
            
            <!-- 发布详情 -->
            <view class="detail-row">
                  <view class="detail-label">分类</view>
                  <view class="detail-value">{{collegeName.name}}</view>
            </view>
            <view class="detail-row">
                  <view class="detail-label">发布</view>
                  <view class="detail-value">{{morejs.timelog(publishinfo.creat)}}</view>
            </view>
            <view class="detail-row">
                  <view class="detail-label">取货</view>
                  <view class="detail-value">{{publishinfo.deliveryid == 0 ? '自提' : '帮送'}}</view>
            </view>
            <view class="detail-row" wx:if="{{publishinfo.deliveryid == 0}}">
                  <view class="detail-label">地点</view>
                  <view class="detail-value">{{publishinfo.place}}</view>
            </view>
            
            <!-- 收货地址 -->
            <view class="address-input" wx:if="{{publishinfo.deliveryid == 1}}">
                  <input 
                        bindinput="placeInput" 
                        placeholder="请输入您的收货地址"
                        placeholder-class="placeholder"
                  />
            </view>
            
            <!-- 备注 -->
            <view class="note-section" wx:if="{{publishinfo.notes}}">
                  <view class="note-label">备注</view>
                  <view class="note-content">{{publishinfo.notes}}</view>
            </view>
      </view>
      
      <!-- 图书详情 -->
      <view class="tab-content" hidden="{{first_title}}">
            <view class="book-detail-list">
                  <view class="detail-row">
                        <view class="detail-label">ISBN</view>
                        <view class="detail-value">{{bookinfo.isbn}}</view>
                  </view>
                  <view class="detail-row">
                        <view class="detail-label">出版社</view>
                        <view class="detail-value">{{bookinfo.publisher}}</view>
                  </view>
                  <view class="detail-row">
                        <view class="detail-label">出版地</view>
                        <view class="detail-value">{{bookinfo.pubplace}}</view>
                  </view>
                  <view class="detail-row">
                        <view class="detail-label">出版时间</view>
                        <view class="detail-value">{{bookinfo.pubdate}}</view>
                  </view>
                  <view class="detail-row">
                        <view class="detail-label">装帧</view>
                        <view class="detail-value">{{bookinfo.binding}}</view>
                  </view>
                  <view class="detail-row">
                        <view class="detail-label">开本</view>
                        <view class="detail-value">{{bookinfo.format}}</view>
                  </view>
                  <view class="detail-row">
                        <view class="detail-label">分类</view>
                        <view class="detail-value">{{bookinfo.class}}</view>
                  </view>
            </view>
            
            <view class="summary-section" wx:if="{{bookinfo.summary}}">
                  <view class="summary-label">内容简介</view>
                  <view class="summary-content">{{bookinfo.summary}}</view>
            </view>
      </view>
</view>

<!-- 底部占位 -->
<view style="height: 140rpx;"></view>

<!-- 底部操作栏 -->
<view class="bottom-bar">
      <view class="action-btns">
            <view class="action-btn" bindtap="home">
                  <image src="/images/home.png"></image>
                  <text>首页</text>
            </view>
            <view class="action-btn" bindtap="contactUser">
                  <image src="/images/message.png"></image>
                  <text>联系</text>
            </view>
            <view class="action-btn" bindtap="go" data-go="/pages/kefu/kefu">
                  <image src="/images/contact.png"></image>
                  <text>反馈</text>
            </view>
            <view class="action-btn">
                  <image src="/images/share.png"></image>
                  <text>分享</text>
                  <button class="share-mask" open-type="share"></button>
            </view>
      </view>
      <view class="buy-btn {{publishinfo.status == 0 ? '' : 'disabled'}}" bindtap="buy">
            {{publishinfo.status == 0 ? '立即购买' : '已售出'}}
      </view>
</view>
