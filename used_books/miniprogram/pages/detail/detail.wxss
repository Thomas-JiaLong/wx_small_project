/* ==================== 书籍封面 ==================== */
.book-header {
      width: 100%;
      height: 480rpx;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(180deg, #0d1320 0%, #0a0f1a 100%);
      padding: 32rpx;
}

.book-cover {
      width: 320rpx;
      height: 400rpx;
      border-radius: 16rpx;
      box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.6);
}

/* ==================== 价格信息 ==================== */
.price-section {
      display: flex;
      align-items: baseline;
      gap: 20rpx;
      padding: 32rpx;
      background: #0d1320;
}

.current-price {
      font-size: 48rpx;
      font-weight: 700;
      color: #00d4ff;
}

.original-price {
      font-size: 28rpx;
      color: rgba(255, 255, 255, 0.4);
      text-decoration: line-through;
}

/* ==================== 书籍信息卡片 ==================== */
.book-info-card {
      padding: 32rpx;
      background: #0d1320;
      margin-top: 2rpx;
}

.book-title {
      font-size: 36rpx;
      font-weight: 600;
      color: rgba(255, 255, 255, 0.95);
      line-height: 1.4;
}

.book-edition {
      font-size: 26rpx;
      color: rgba(255, 255, 255, 0.5);
      margin-top: 12rpx;
}

.book-author {
      font-size: 28rpx;
      color: rgba(255, 255, 255, 0.6);
      margin-top: 16rpx;
}

/* ==================== 标签切换 ==================== */
.tab-section {
      margin-top: 16rpx;
}

.tab-header {
      display: flex;
      background: #0d1320;
      border-bottom: 1rpx solid rgba(0, 212, 255, 0.1);
}

.tab-item {
      flex: 1;
      text-align: center;
      padding: 28rpx 0;
      position: relative;
      transition: all 0.3s ease;
}

.tab-item text {
      font-size: 30rpx;
      color: rgba(255, 255, 255, 0.5);
}

.tab-item.active text {
      color: #00d4ff;
      font-weight: 500;
}

.tab-item.active::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 60rpx;
      height: 6rpx;
      background: linear-gradient(90deg, #00d4ff 0%, #0099cc 100%);
      border-radius: 3rpx;
}

.tab-content {
      padding: 24rpx 32rpx;
      background: #0d1320;
}

/* ==================== 卖家卡片 ==================== */
.seller-card {
      display: flex;
      align-items: center;
      background: rgba(255, 255, 255, 0.03);
      border-radius: 16rpx;
      padding: 24rpx;
      margin-bottom: 24rpx;
      border: 1rpx solid rgba(0, 212, 255, 0.08);
}

.seller-avatar {
      width: 88rpx;
      height: 88rpx;
      border-radius: 50%;
      margin-right: 20rpx;
}

.seller-info {
      flex: 1;
}

.seller-name {
      font-size: 32rpx;
      font-weight: 500;
      color: rgba(255, 255, 255, 0.95);
}

.seller-campus {
      display: flex;
      align-items: center;
      gap: 8rpx;
      margin-top: 8rpx;
}

.seller-campus image {
      width: 28rpx;
      height: 28rpx;
      filter: brightness(0) saturate(100%) invert(85%) sepia(56%) saturate(3132%) hue-rotate(152deg) brightness(99%) contrast(101%);
      opacity: 0.8;
}

.seller-campus text {
      font-size: 26rpx;
      color: rgba(255, 255, 255, 0.5);
}

.seller-gender image {
      width: 40rpx;
      height: 40rpx;
}

/* ==================== 详情行 ==================== */
.detail-row {
      display: flex;
      padding: 20rpx 0;
      border-bottom: 1rpx solid rgba(0, 212, 255, 0.06);
}

.detail-row:last-child {
      border-bottom: none;
}

.detail-label {
      width: 140rpx;
      font-size: 28rpx;
      color: rgba(255, 255, 255, 0.4);
      flex-shrink: 0;
}

.detail-value {
      flex: 1;
      font-size: 28rpx;
      color: rgba(255, 255, 255, 0.85);
}

/* ==================== 地址输入 ==================== */
.address-input {
      margin-top: 20rpx;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 12rpx;
      padding: 24rpx;
}

.address-input input {
      font-size: 28rpx;
      width: 100%;
      color: rgba(255, 255, 255, 0.9);
}

.placeholder {
      color: rgba(255, 255, 255, 0.3);
}

/* ==================== 备注区域 ==================== */
.note-section {
      margin-top: 24rpx;
      padding: 24rpx;
      background: rgba(255, 153, 0, 0.08);
      border-radius: 12rpx;
      border-left: 6rpx solid #ff9900;
}

.note-label {
      font-size: 28rpx;
      color: #ff9900;
      margin-bottom: 12rpx;
}

.note-content {
      font-size: 28rpx;
      color: rgba(255, 255, 255, 0.7);
      line-height: 1.6;
}

/* ==================== 图书详情列表 ==================== */
.book-detail-list {
      background: #0d1320;
}

/* ==================== 内容简介 ==================== */
.summary-section {
      margin-top: 24rpx;
      padding: 24rpx;
      background: rgba(255, 255, 255, 0.03);
      border-radius: 12rpx;
}

.summary-label {
      font-size: 28rpx;
      font-weight: 500;
      color: rgba(255, 255, 255, 0.9);
      margin-bottom: 16rpx;
}

.summary-content {
      font-size: 28rpx;
      color: rgba(255, 255, 255, 0.6);
      line-height: 1.8;
}

/* ==================== 底部操作栏 ==================== */
.bottom-bar {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background: #0d1320;
      display: flex;
      align-items: center;
      padding: 16rpx 24rpx;
      padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
      box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.4);
      border-top: 1rpx solid rgba(0, 212, 255, 0.1);
}

.action-btns {
      display: flex;
      gap: 4rpx;
}

.action-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 12rpx 16rpx;
      position: relative;
      min-width: 80rpx;
      border-radius: 12rpx;
      transition: all 0.2s ease;
}

.action-btn:active {
      background: rgba(0, 212, 255, 0.1);
}

.action-btn image {
      width: 44rpx;
      height: 44rpx;
      filter: brightness(0) saturate(100%) invert(85%) sepia(56%) saturate(3132%) hue-rotate(152deg) brightness(99%) contrast(101%);
}

.action-btn text {
      font-size: 22rpx;
      color: rgba(255, 255, 255, 0.6);
      margin-top: 6rpx;
      letter-spacing: 0.5rpx;
}

.action-btn:active text {
      color: #00d4ff;
}

.share-mask {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      opacity: 0;
}

.share-mask::after {
      border: none;
}

.buy-btn {
      flex: 1;
      margin-left: 20rpx;
      height: 88rpx;
      background: linear-gradient(135deg, #00d4ff 0%, #0099cc 100%);
      border-radius: 44rpx;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 32rpx;
      font-weight: 600;
      color: #fff;
      letter-spacing: 2rpx;
      box-shadow: 0 8rpx 24rpx rgba(0, 212, 255, 0.35);
      transition: all 0.3s ease;
}

.buy-btn:active {
      transform: scale(0.98);
      box-shadow: 0 4rpx 16rpx rgba(0, 212, 255, 0.25);
}

.buy-btn.disabled {
      background: rgba(255, 255, 255, 0.08);
      color: rgba(255, 255, 255, 0.4);
      box-shadow: none;
}
