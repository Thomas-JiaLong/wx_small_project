/* ==================== 书籍头部 ==================== */
.book-header {
      background: var(--primary-gradient);
      padding: 40rpx;
      display: flex;
      justify-content: center;
      align-items: center;
}

.book-cover {
      width: 320rpx;
      height: 400rpx;
      border-radius: var(--border-radius-lg);
      box-shadow: var(--shadow-lg);
}

/* ==================== 价格区域 ==================== */
.price-section {
      display: flex;
      align-items: baseline;
      gap: 16rpx;
      padding: 32rpx 40rpx;
      background: var(--bg-card);
}

.current-price {
      font-size: 56rpx;
      font-weight: 700;
      color: var(--error-color);
}

.original-price {
      font-size: 28rpx;
      color: var(--text-placeholder);
      text-decoration: line-through;
}

/* ==================== 书籍信息卡片 ==================== */
.book-info-card {
      background: var(--bg-card);
      padding: 0 40rpx 32rpx;
      border-bottom: 16rpx solid var(--bg-page);
}

.book-title {
      font-size: 40rpx;
      font-weight: 600;
      color: var(--text-primary);
      line-height: 1.4;
}

.book-edition {
      display: inline-block;
      margin-top: 12rpx;
      padding: 6rpx 16rpx;
      background: rgba(102, 126, 234, 0.1);
      color: var(--primary-color);
      font-size: 24rpx;
      border-radius: 8rpx;
}

.book-author {
      font-size: 30rpx;
      color: var(--text-secondary);
      margin-top: 16rpx;
}

/* ==================== 标签切换 ==================== */
.tab-section {
      background: var(--bg-card);
      margin-top: 16rpx;
}

.tab-header {
      display: flex;
      border-bottom: 1rpx solid var(--border-color);
}

.tab-item {
      flex: 1;
      text-align: center;
      padding: 28rpx 0;
      position: relative;
      transition: all 0.3s ease;
}

.tab-item text {
      font-size: 30rpx;
      color: var(--text-secondary);
}

.tab-item.active text {
      color: var(--primary-color);
      font-weight: 600;
}

.tab-item.active::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 60rpx;
      height: 6rpx;
      background: var(--primary-gradient);
      border-radius: 3rpx;
}

.tab-content {
      padding: 24rpx 32rpx;
}

/* ==================== 卖家卡片 ==================== */
.seller-card {
      display: flex;
      align-items: center;
      background: var(--bg-input);
      border-radius: var(--border-radius-lg);
      padding: 24rpx;
      margin-bottom: 24rpx;
}

.seller-avatar {
      width: 88rpx;
      height: 88rpx;
      border-radius: 50%;
      margin-right: 20rpx;
}

.seller-info {
      flex: 1;
}

.seller-name {
      font-size: 32rpx;
      font-weight: 500;
      color: var(--text-primary);
}

.seller-campus {
      display: flex;
      align-items: center;
      gap: 8rpx;
      margin-top: 8rpx;
}

.seller-campus image {
      width: 28rpx;
      height: 28rpx;
      opacity: 0.6;
}

.seller-campus text {
      font-size: 26rpx;
      color: var(--text-secondary);
}

.seller-gender image {
      width: 40rpx;
      height: 40rpx;
}

/* ==================== 详情行 ==================== */
.detail-row {
      display: flex;
      padding: 20rpx 0;
      border-bottom: 1rpx solid var(--border-color);
}

.detail-row:last-child {
      border-bottom: none;
}

.detail-label {
      width: 140rpx;
      font-size: 28rpx;
      color: var(--text-placeholder);
      flex-shrink: 0;
}

.detail-value {
      flex: 1;
      font-size: 28rpx;
      color: var(--text-primary);
}

/* ==================== 地址输入 ==================== */
.address-input {
      margin-top: 20rpx;
      background: var(--bg-input);
      border-radius: var(--border-radius);
      padding: 24rpx;
}

.address-input input {
      font-size: 28rpx;
      width: 100%;
}

.placeholder {
      color: var(--text-placeholder);
}

/* ==================== 备注区域 ==================== */
.note-section {
      margin-top: 24rpx;
      padding: 24rpx;
      background: rgba(255, 153, 0, 0.05);
      border-radius: var(--border-radius);
      border-left: 6rpx solid #ff9900;
}

.note-label {
      font-size: 28rpx;
      color: #ff9900;
      margin-bottom: 12rpx;
}

.note-content {
      font-size: 28rpx;
      color: var(--text-secondary);
      line-height: 1.6;
}

/* ==================== 图书详情列表 ==================== */
.book-detail-list {
      background: var(--bg-card);
}

/* ==================== 内容简介 ==================== */
.summary-section {
      margin-top: 24rpx;
      padding: 24rpx;
      background: var(--bg-input);
      border-radius: var(--border-radius);
}

.summary-label {
      font-size: 28rpx;
      font-weight: 500;
      color: var(--text-primary);
      margin-bottom: 16rpx;
}

.summary-content {
      font-size: 28rpx;
      color: var(--text-secondary);
      line-height: 1.8;
}

/* ==================== 底部操作栏 ==================== */
.bottom-bar {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background: var(--bg-card);
      display: flex;
      align-items: center;
      padding: 16rpx 24rpx;
      padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
      box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.action-btns {
      display: flex;
      gap: 8rpx;
}

.action-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 8rpx 20rpx;
      position: relative;
}

.action-btn image {
      width: 44rpx;
      height: 44rpx;
}

.action-btn text {
      font-size: 22rpx;
      color: var(--text-secondary);
      margin-top: 4rpx;
}

.share-mask {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      opacity: 0;
}

.share-mask::after {
      border: none;
}

.buy-btn {
      flex: 1;
      margin-left: 20rpx;
      height: 88rpx;
      background: var(--primary-gradient);
      border-radius: 44rpx;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 32rpx;
      font-weight: 500;
      color: #fff;
      letter-spacing: 2rpx;
      box-shadow: var(--shadow-primary);
      transition: all 0.3s ease;
}

.buy-btn:active {
      transform: scale(0.98);
}

.buy-btn.disabled {
      background: #ccc;
      box-shadow: none;
}
