/* ==================== 协议页面样式 ==================== */

page {
      background: #0a0f1a;
      color: #fff;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
}

.container {
      height: 100vh;
      display: flex;
      flex-direction: column;
}

/* 顶部导航栏 */
.nav-bar {
      height: 100rpx;
      background: rgba(13, 19, 32, 0.8);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 32rpx;
      border-bottom: 1rpx solid rgba(0, 212, 255, 0.1);
      position: sticky;
      top: 0;
      z-index: 100;
      backdrop-filter: blur(10rpx);
}

.back-btn {
      width: 48rpx;
      height: 48rpx;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 12rpx;
      background: rgba(255, 255, 255, 0.05);
      transition: all 0.3s ease;
}

.back-btn:hover {
      background: rgba(255, 255, 255, 0.1);
}

.back-btn image {
      width: 24rpx;
      height: 24rpx;
      opacity: 0.8;
}

.nav-title {
      font-size: 32rpx;
      font-weight: 600;
      color: #fff;
      letter-spacing: 2rpx;
}

.nav-right {
      width: 48rpx;
}

/* 内容区域 */
.content {
      flex: 1;
      overflow-y: auto;
}

.content-wrapper {
      padding: 40rpx 32rpx;
}

/* 章节 */
.section {
      margin-bottom: 48rpx;
}

.section-title {
      font-size: 32rpx;
      font-weight: 600;
      color: #00d4ff;
      margin-bottom: 24rpx;
      letter-spacing: 2rpx;
}

.section-content {
      line-height: 1.6;
}

/* 段落 */
.paragraph {
      margin-bottom: 32rpx;
}

.paragraph:last-child {
      margin-bottom: 0;
}

/* 小标题 */
.sub-title {
      font-size: 24rpx;
      font-weight: 600;
      color: #fff;
      margin-bottom: 16rpx;
      letter-spacing: 1rpx;
}

/* 正文 */
.text {
      font-size: 22rpx;
      color: rgba(255, 255, 255, 0.7);
      margin-bottom: 12rpx;
      line-height: 1.6;
}

.text:last-child {
      margin-bottom: 0;
}

/* 响应式设计 */
@media (max-width: 375px) {
      .content-wrapper {
            padding: 32rpx 24rpx;
      }
      
      .section-title {
            font-size: 28rpx;
      }
      
      .sub-title {
            font-size: 22rpx;
      }
      
      .text {
            font-size: 20rpx;
      }
}
