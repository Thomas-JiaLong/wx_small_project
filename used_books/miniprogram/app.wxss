/* ==================== 科技感主题变量 ==================== */
page {
      --primary-color: #00d4ff;
      --primary-light: #0099cc;
      --primary-gradient: linear-gradient(135deg, #00d4ff 0%, #0099cc 100%);
      --primary-bg: rgba(0, 212, 255, 0.1);
      
      --bg-page: #0a0f1a;
      --bg-card: #0d1320;
      --bg-input: rgba(255, 255, 255, 0.05);
      
      --text-primary: rgba(255, 255, 255, 0.95);
      --text-secondary: rgba(255, 255, 255, 0.6);
      --text-placeholder: rgba(255, 255, 255, 0.35);
      
      --border-color: rgba(0, 212, 255, 0.15);
      --border-color-light: rgba(0, 212, 255, 0.08);
      
      --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
      --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.4);
      --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.5);
      --shadow-primary: 0 8rpx 24rpx rgba(0, 212, 255, 0.35);
      --shadow-glow: 0 0 20rpx rgba(0, 212, 255, 0.2);
      
      --border-radius: 12rpx;
      --border-radius-lg: 20rpx;
      
      --spacing-xs: 8rpx;
      --spacing-sm: 16rpx;
      --spacing-md: 24rpx;
      --spacing-lg: 32rpx;
      --spacing-xl: 48rpx;
      
      --font-size-xs: 22rpx;
      --font-size-sm: 26rpx;
      --font-size-md: 30rpx;
      --font-size-lg: 36rpx;
      --font-size-xl: 44rpx;
      
      background: var(--bg-page);
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      color: var(--text-primary);
      font-size: var(--font-size-md);
      line-height: 1.5;
}

/* ==================== 通用样式 ==================== */
button {
      margin: 0;
      padding: 0;
      background: transparent;
      line-height: inherit;
}

button::after {
      border: none;
}

input, textarea {
      color: var(--text-primary);
}

input::placeholder, textarea::placeholder {
      color: var(--text-placeholder);
}

/* ==================== 通用工具类 ==================== */
.text-cut {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
}

.text-cut-2 {
      overflow: hidden;
      text-overflow: ellipsis;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
}

.flex-row {
      display: flex;
      flex-direction: row;
}

.flex-col {
      display: flex;
      flex-direction: column;
}

.flex-center {
      display: flex;
      align-items: center;
      justify-content: center;
}

.flex-between {
      display: flex;
      align-items: center;
      justify-content: space-between;
}

/* ==================== 卡片组件 ==================== */
.card {
      background: var(--bg-card);
      border-radius: var(--border-radius-lg);
      padding: var(--spacing-lg);
      border: 1rpx solid var(--border-color-light);
}

.card-shadow {
      box-shadow: var(--shadow-lg);
}

/* ==================== 按钮组件 ==================== */
.btn-primary {
      background: var(--primary-gradient);
      color: #fff;
      border-radius: 48rpx;
      font-weight: 500;
      box-shadow: var(--shadow-primary);
      border: none;
}

.btn-primary::after {
      border: none;
}

.btn-secondary {
      background: var(--bg-card);
      color: var(--primary-color);
      border-radius: 48rpx;
      border: 2rpx solid var(--primary-color);
}

.btn-secondary::after {
      border: none;
}

/* ==================== 价格样式 ==================== */
.price {
      color: var(--primary-color);
      font-weight: 600;
}

.price-large {
      font-size: 44rpx;
}

.price-medium {
      font-size: 36rpx;
}

.price-small {
      font-size: 28rpx;
}

/* ==================== 标签样式 ==================== */
.tag {
      display: inline-flex;
      align-items: center;
      padding: 8rpx 16rpx;
      font-size: var(--font-size-xs);
      border-radius: 20rpx;
      background: var(--primary-bg);
      color: var(--primary-color);
}

.tag-primary {
      background: var(--primary-gradient);
      color: #fff;
}

/* ==================== 空状态 ==================== */
.empty-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 80rpx 40rpx;
}

.empty-state image {
      width: 240rpx;
      height: 200rpx;
      opacity: 0.5;
      filter: grayscale(30%);
}

.empty-state text {
      margin-top: 24rpx;
      font-size: var(--font-size-sm);
      color: var(--text-placeholder);
}

/* ==================== 加载更多 ==================== */
.loadmore {
      text-align: center;
      padding: 32rpx;
      color: var(--text-placeholder);
      font-size: var(--font-size-sm);
}

/* ==================== 回到顶部 ==================== */
.back-top {
      position: fixed;
      right: 32rpx;
      bottom: 200rpx;
      width: 88rpx;
      height: 88rpx;
      background: rgba(0, 212, 255, 0.15);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1rpx solid rgba(0, 212, 255, 0.3);
}

.back-top image {
      width: 44rpx;
      height: 44rpx;
      filter: brightness(0) saturate(100%) invert(85%) sepia(56%) saturate(3132%) hue-rotate(152deg) brightness(99%) contrast(101%);
}

/* ==================== 动画 ==================== */
@keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
}

@keyframes slideUp {
      from {
            opacity: 0;
            transform: translateY(40rpx);
      }
      to {
            opacity: 1;
            transform: translateY(0);
      }
}

@keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.5; }
}

@keyframes glow {
      0%, 100% { 
            box-shadow: 0 0 20rpx rgba(0, 212, 255, 0.3);
      }
      50% { 
            box-shadow: 0 0 40rpx rgba(0, 212, 255, 0.6);
      }
}

.fade-in {
      animation: fadeIn 0.3s ease;
}

.slide-up {
      animation: slideUp 0.4s ease;
}

.pulse {
      animation: pulse 2s infinite;
}

.glow {
      animation: glow 2s infinite;
}

/* ==================== 科技感装饰 ==================== */
/* 网格背景效果 */
.grid-bg {
      background-image: 
            linear-gradient(rgba(0, 212, 255, 0.02) 1px, transparent 1px),
            linear-gradient(90deg, rgba(0, 212, 255, 0.02) 1px, transparent 1px);
      background-size: 40rpx 40rpx;
}

/* 扫描线效果 */
.scan-line {
      position: relative;
      overflow: hidden;
}

.scan-line::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2rpx;
      background: linear-gradient(90deg, transparent, var(--primary-color), transparent);
      animation: scan 3s linear infinite;
}

@keyframes scan {
      0% { top: 0; opacity: 1; }
      100% { top: 100%; opacity: 0; }
}

/* ==================== 图标颜色统一 ==================== */
/* 将图标颜色统一为科技感青色 #00d4ff */
.icon-cyan {
      filter: brightness(0) saturate(100%) invert(85%) sepia(56%) saturate(3132%) hue-rotate(152deg) brightness(99%) contrast(101%);
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
      width: 0;
      height: 0;
      color: transparent;
}
