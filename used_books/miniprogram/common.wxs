// 公共 WXS 工具模块（优化版）
// 缓存当前时间，减少重复计算

var _cachedNow = 0;
var _cachedMinute = 0;

function getNowMinute() {
  var now = getDate().getTime();
  // 每分钟更新一次缓存
  if (now - _cachedMinute > 60000) {
    _cachedMinute = now;
    _cachedNow = now;
  }
  return _cachedNow;
}

// 友好时间显示：刚刚/x分钟前/x小时前/x天前/M月D日
function timelog(dateStr) {
  if (!dateStr) return '';
  
  var publishTime = parseInt(dateStr) || 0;
  if (publishTime <= 0) return '';
  
  var nowTime = getNowMinute();
  var diffValue = Math.floor((nowTime - publishTime) / 1000);
  
  if (diffValue < 0) diffValue = 0;
  
  var days = Math.floor(diffValue / 86400);
  var hours = Math.floor(diffValue / 3600);
  var minutes = Math.floor(diffValue / 60);
  
  if (diffValue < 60) {
    return '刚刚';
  }
  if (minutes < 60) {
    return minutes + '分钟前';
  }
  if (hours < 24) {
    return hours + '小时前';
  }
  if (days < 7) {
    return days + '天前';
  }
  
  // 超过7天显示日期
  var date = getDate(publishTime);
  var M = date.getMonth() + 1;
  var D = date.getDate();
  return M + '月' + D + '日';
}

// 标准日期格式：YYYY-MM-DD HH:mm
function format(dateStr) {
  if (!dateStr) return '';
  
  var date = getDate(dateStr);
  var Y = date.getFullYear();
  var M = padZero(date.getMonth() + 1);
  var D = padZero(date.getDate());
  var H = padZero(date.getHours());
  var m = padZero(date.getMinutes());
  
  return Y + '-' + M + '-' + D + ' ' + H + ':' + m;
}

// 补零
function padZero(n) {
  return n < 10 ? '0' + n : '' + n;
}

module.exports = {
  timelog: timelog,
  format: format
};
